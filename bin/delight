#!/usr/bin/env perl

use strict;
use warnings;
# Installed via Makefile.PL, modules should be in @INC
use Delight::Config;
use Delight::Dooray;
use Getopt::Long;
use JSON::XS;
use File::Spec;
use File::HomeDir;
use File::Path qw(make_path);
use Encode qw(encode_utf8 decode_utf8);
use POSIX qw(strftime);
use Time::Piece;
use Fcntl;
use SDBM_File;

# Ensure UTF-8 for terminal and command-line arguments
use open qw(:std :utf8);
binmode STDOUT, ":utf8";
@ARGV = map { decode_utf8($_) } @ARGV;
binmode STDERR, ":utf8";

my $config = Delight::Config->new();
my $dooray = Delight::Dooray->new(
    token  => $config->get('token'),
    domain => $config->get('domain'),
);

my $command = shift @ARGV || 'help';

# --- Helpers ---

sub base_dir {
    $config->get('download_dir') || File::Spec->catdir(File::HomeDir->my_home, 'delight');
}

sub resolve_wiki_id {
    my ($wiki_id, $page_id, $project_id) = @_;
    return $wiki_id if $wiki_id;
    if ($page_id) {
        my $info = eval { $dooray->get_wiki_page($page_id) };
        return $info->{result}{wikiId} if $info && $info->{result}{wikiId};
    }
    $wiki_id = $config->get('default_wiki_id');
    return $wiki_id if $wiki_id;
    $project_id ||= $config->get('default_project_id');
    if ($project_id) {
        return eval { $dooray->get_wiki_id_by_project_id($project_id) };
    }
    return undef;
}

sub resolve_project_id {
    my ($project_id, $task_id) = @_;
    return $project_id if $project_id;
    if ($task_id) {
        my $info = eval { $dooray->get_post($task_id) };
        return $info->{result}{project}{id} if $info && $info->{result}{project};
    }
    return $config->get('default_project_id');
}

if ($command eq 'whoami') {
    my $data = $dooray->whoami();
    print "Name: " . $data->{result}{name} . "\n";
    print "Email: " . $data->{result}{externalEmailAddress} . "\n";
} elsif ($command eq 'project') {
    my $sub = shift @ARGV;
    if ($sub eq 'list') {
        my $data = $dooray->list_projects();
        foreach my $p (@{$data->{result}}) {
            printf "%-25s | %s\n", $p->{id}, $p->{code};
        }
    } elsif ($sub eq 'settings') {
        my $project_id;
        GetOptions("project-id=s" => \$project_id);
        $project_id ||= shift @ARGV || $config->get('default_project_id');
        die "Usage: delight project settings [--project-id <id>]\n" unless $project_id;

        my $workflows = $dooray->list_workflows($project_id);
        my $milestones = $dooray->list_milestones($project_id);
        my $tags = $dooray->list_tags($project_id);
        my $members = $dooray->list_project_members($project_id);

        my $output = "# Project Settings ($project_id)\n\n";

        $output .= "## Status (Workflows)\n\n";
        $output .= sprintf "%-25s | %-15s | %s\n", "ID", "Class", "Name";
        $output .= "-" x 60 . "\n";
        for my $w (@{$workflows->{result} || []}) {
            $output .= sprintf "%-25s | %-15s | %s\n", $w->{id}, $w->{class}, $w->{name};
        }

        $output .= "\n## Phases (Milestones)\n\n";
        $output .= sprintf "%-25s | %-15s | %s\n", "ID", "Status", "Name";
        $output .= "-" x 60 . "\n";
        for my $m (@{$milestones->{result} || []}) {
            $output .= sprintf "%-25s | %-15s | %s\n", $m->{id}, $m->{status} || '', $m->{name};
        }

        $output .= "\n## Tags\n\n";
        $output .= sprintf "%-25s | %s\n", "ID", "Name";
        $output .= "-" x 40 . "\n";
        for my $t (@{$tags->{result} || []}) {
            $output .= sprintf "%-25s | %s\n", $t->{id}, $t->{name};
        }

        $output .= "\n## Members\n\n";
        $output .= sprintf "%-25s | %-15s | %s\n", "ID", "Role", "Name";
        $output .= "-" x 60 . "\n";
        for my $m (@{$members->{result} || []}) {
            my $id = $m->{organizationMemberId} || '';
            my $role = $m->{role} || '';
            my $name = '';
            if ($id) {
                my $info = eval { $dooray->request('GET', "/common/v1/members/$id") };
                $name = $info->{result}{name} || '' if $info;
            }
            $output .= sprintf "%-25s | %-15s | %s\n", $id, $role, $name;
        }

        print $output;

        # Save to file
        my $base_dir = base_dir();
        my $proj_dir = File::Spec->catdir($base_dir, "project_$project_id");
        make_path($proj_dir) unless -d $proj_dir;
        my $fpath = File::Spec->catfile($proj_dir, "settings.md");
        open my $fh, '>:encoding(UTF-8)', $fpath or die "Could not open $fpath: $!\n";
        print $fh $output;
        close $fh;
        print "\nSaved to $fpath\n";
    }
} elsif ($command eq 'calendar') {
    my $sub = shift @ARGV;
    if ($sub eq '+agenda') {
        my ($today, $week, $days, $timezone);
        GetOptions(
            "today"      => \$today,
            "week"       => \$week,
            "days=i"     => \$days,
            "timezone=s" => \$timezone,
        );

        my $now = time;
        my $duration_days = 1;
        $duration_days = 7 if $week;
        $duration_days = $days if $days;
        
        my $start_of_period = strftime("%Y-%m-%dT00:00:00+09:00", localtime($now));
        my $end_of_period   = strftime("%Y-%m-%dT23:59:59+09:00", localtime($now + ($duration_days - 1) * 86400));
        
        my $data = $dooray->list_events($start_of_period, $end_of_period);
        print "Agenda ($start_of_period to $end_of_period):\n";
        foreach my $event (@{$data->{result}}) {
            my $start = $event->{startedAt} || 'All Day';
            printf " [%-25s] %s\n", $start, $event->{subject};
        }
    } elsif ($sub eq 'events' || $sub eq '+insert' || $sub eq '+quickAdd') {
        my $action = ($sub eq '+insert') ? 'create' : (($sub eq '+quickAdd') ? 'create' : shift @ARGV);
        if ($action eq 'create' || $action eq 'insert' || $action eq 'quickAdd') {
            my ($subject, $summary, $start, $end, $location, $calendar_id, $params_meta, @attendees, $text, $busy);
            GetOptions(
                "subject=s"     => \$subject,
                "summary=s"     => \$summary,
                "start=s"       => \$start,
                "end=s"         => \$end,
                "location=s"    => \$location,
                "calendarId=s"  => \$calendar_id,
                "calendar-id=s" => \$calendar_id,
                "params=s"      => \$params_meta,
                "attendee=s"    => \@attendees,
                "text=s"        => \$text,
                "busy"          => \$busy,
                "public"        => \my $public,
            );
            $subject ||= $summary || $text || shift @ARGV;
            
            if ($params_meta) {
                my $context = join(' ', $params_meta, @ARGV);
                $context =~ s/\\(["'])/$1/g;
                if ($context =~ /summary\W+([^"',}\s]+)/i || $context =~ /subject\W+([^"',}\s]+)/i) {
                    $subject = $1;
                }
                if ($context =~ /startedAt\W+([^"',}\s]+|{[^}]+})\W+endedAt/i) {
                   # handle nested later if needed
                }
                if ($context =~ /dateTime\W+([^"',}\s]+)/i) {
                    $start = $1;
                }
            }
            
            die "Usage: delight calendar +insert --summary <subject>\n" unless $subject;
            
            
            $calendar_id ||= $config->get('default_calendar_id');
            if (!$calendar_id || $calendar_id eq 'primary') {
                $calendar_id = $dooray->get_default_calendar_id();
            }
            
    

            my $now = time;
            if ($start) {
                if (!$end) {
                    eval {
                        # Dooray format: 2026-03-22T20:00:00+09:00
                        my $s_clean = $start;
                        $s_clean =~ s/(\+\d{2}):(\d{2})$/$1$2/; # Remove colon for strptime %z
                        my $t = Time::Piece->strptime($s_clean, "%Y-%m-%dT%H:%M:%S%z");
                        my $t_end = $t + 3600;
                        $end = $t_end->strftime("%Y-%m-%dT%H:%M:%S");
                        my $tz = $t_end->strftime("%z");
                        $tz =~ s/(\d{2})(\d{2})$/$1:$2/; # Add colon back
                        $end .= $tz;
                    };
                    if ($@ || !$end) {
                        $end = $start; $end =~ s/T(\d{2})/sprintf("T%02d", ($1+1)%24)/e;
                    }
                }
            } else {
                $start = strftime("%Y-%m-%dT%H:%M:%S+09:00", localtime($now + 3600));
                $end   ||= strftime("%Y-%m-%dT%H:%M:%S+09:00", localtime($now + 7200));
            }
            
            my @to_members = ({ type => 'member', member => { organizationMemberId => $dooray->whoami()->{result}{id} } });
            for my $att (@attendees) {
                my $search_res = ($att =~ /@/) ? $dooray->search_members_by_email($att) : $dooray->search_members($att);
                my $members = $search_res->{result} || [];
                if (@$members) {
                    my $m = $members->[0];
                    push @to_members, { type => 'member', member => { organizationMemberId => $m->{id} } };
                    print "Attendee added: $m->{name}\n";
                } else {
                    warn "Warning: Member '$att' not found, skipped.\n";
                }
            }

            my $event_data = {
                users     => { to => \@to_members },
                subject   => $subject,
                body      => { mimeType => "text/plain", content => "Created via Delight CLI" },
                startedAt => $start,
                endedAt   => $end,
                location  => $location || "",
                personalSettings => {
                    busy  => $busy ? JSON::XS::true : JSON::XS::false,
                    class => $public ? "public" : "private",
                },
            };

            my $res = $dooray->create_event($calendar_id, $event_data);
            print "Event created successfully! ID: " . $res->{result}{id} . "\n";
        } elsif ($action eq 'list') {
            my ($calendar_id, $max_results, $q);
            GetOptions(
                "calendarId=s"  => \$calendar_id,
                "calendar-id=s" => \$calendar_id,
                "maxResults=i"  => \$max_results,
                "q=s"           => \$q,
            );
            $calendar_id ||= $config->get('default_calendar_id') || 'primary';
            if ($calendar_id eq 'primary') {
                $calendar_id = '*'; # Dooray wildcard
            }
            
    
            my $now = time;
            my $start = strftime("%Y-%m-%dT00:00:00+09:00", localtime($now - 7 * 86400)); # Last 7 days
            my $end   = strftime("%Y-%m-%dT23:59:59+09:00", localtime($now + 7 * 86400)); # Next 7 days
            
            my $data = $dooray->list_events($start, $end, q => $q, maxResults => $max_results);
            foreach my $event (@{$data->{result}}) {
                if ($calendar_id ne '*' && $event->{calendar}{id} ne $calendar_id) {
                    next;
                }
                printf "%-25s | %-25s | %-25s | %s\n", $event->{id}, $event->{calendar}{id} || "unknown", $event->{startedAt} || "All Day", $event->{subject};
            }
        } elsif ($action eq 'get' || $action eq 'delete' || $action eq 'update') {
            my ($calendar_id, $event_id, $summary, $start, $end, $location, $delete_type);
            GetOptions(
                "calendarId=s"  => \$calendar_id,
                "eventId=s"     => \$event_id,
                "summary=s"     => \$summary,
                "start=s"       => \$start,
                "end=s"         => \$end,
                "location=s"    => \$location,
                "deleteType=s"  => \$delete_type,
            );
            $event_id ||= shift @ARGV;
            die "Usage: delight calendar events $action --eventId <id>\n" unless $event_id;

            if (!$calendar_id || $calendar_id eq 'primary') {
                $calendar_id = $dooray->get_default_calendar_id();
            }

            if ($action eq 'get') {
                my $res = $dooray->get_event($calendar_id, $event_id);
                print "Event ID:    " . $res->{result}{id} . "\n";
                print "Subject:     " . $res->{result}{subject} . "\n";
                print "Started At:  " . ($res->{result}{startedAt} || "N/A") . "\n";
                print "Ended At:    " . ($res->{result}{endedAt} || "N/A") . "\n";
                print "Location:    " . ($res->{result}{location} || "") . "\n";
            } elsif ($action eq 'delete') {
                $dooray->delete_event($calendar_id, $event_id, deleteType => $delete_type);
                print "Event deleted successfully.\n";
            } elsif ($action eq 'update') {
                my $event = $dooray->get_event($calendar_id, $event_id)->{result};
                $event->{subject}   = $summary  if defined $summary;
                $event->{startedAt} = $start    if defined $start;
                $event->{endedAt}   = $end      if defined $end;
                $event->{location}  = $location if defined $location;
                $dooray->update_event($calendar_id, $event_id, $event);
                print "Event updated successfully.\n";
            }
        } elsif ($action eq 'invite') {
            my ($calendar_id, $event_id, $name);
            GetOptions(
                "calendarId=s" => \$calendar_id,
                "eventId=s"    => \$event_id,
                "name=s"       => \$name,
            );
            $event_id ||= shift @ARGV;
            $name     ||= join(' ', @ARGV);
            
            die "Usage: delight calendar invite <eventId> <name>\n" unless $event_id && $name;

            if (!$calendar_id || $calendar_id eq 'primary') {
                $calendar_id = $dooray->get_default_calendar_id();
            }

            # 1. Search for member
            my $search_res = $dooray->search_members($name);
            my $members = $search_res->{result} || [];
            die "Error: Member '$name' not found.\n" unless @$members;
            
            my $member = $members->[0]; # Take first match
            print "Found member: $member->{name} ($member->{externalEmailAddress})\n";

            # 2. Get current event to preserve data
            my $event = $dooray->get_event($calendar_id, $event_id)->{result};
            
            # 3. Add to attendees
            $event->{users} ||= { to => [] };
            push @{$event->{users}{to}}, {
                type   => 'member',
                member => { organizationMemberId => $member->{id} }
            };

            # 4. Update
            $dooray->update_event($calendar_id, $event_id, $event);
            print "Successfully invited $member->{name} to event $event_id\n";
        }
    } elsif ($sub eq 'freebusy') {
        my $action = shift @ARGV;
        if ($action eq 'query') {
            my $params_meta;
            GetOptions("params=s" => \$params_meta);
            # Note: Dooray free-busy query might need translation from GWS style
            # For now, just pass through if it's JSON
            if ($params_meta) {
                 my $json = JSON::XS->new->utf8->pretty;
                 my $res = $dooray->query_freebusy($json->decode($params_meta));
                 print "Free-Busy Query result:\n";
                 print $json->encode($res) . "\n";
            }
        }
    }
} elsif ($command eq 'drive') {
    my $sub = shift @ARGV;
    my ($json_meta, $params_meta, $upload_path, $name, $parent_id, $drive_id, $project_id, $wiki_id, $size);

    if ($sub eq 'files') {
        my $action = shift @ARGV;
        if ($action eq 'create') {
            GetOptions(
                "json=s"      => \$json_meta,
                "upload=s"    => \$upload_path,
                "name=s"      => \$name,
                "parent-id=s" => \$parent_id,
                "drive-id=s"  => \$drive_id,
                "project-id=s"=> \$project_id,
                "wiki-id=s"   => \$wiki_id,
            );
        } elsif ($action eq 'list') {
            GetOptions(
                "params=s"    => \$params_meta,
                "size=i"      => \$size,
                "drive-id=s"  => \$drive_id,
                "project-id=s"=> \$project_id,
                "wiki-id=s"   => \$wiki_id,
            );
            
            if ($params_meta) {
                my $context = join(' ', $params_meta, @ARGV);
                $context =~ s/\\(["'])/$1/g;
                if ($context =~ /pageSize\W+(\d+)/i) {
                    $size = $1;
                }
            }
            $size ||= 5;
        }
    } elsif ($sub eq '+upload') {
        $upload_path = shift @ARGV;
        GetOptions("name=s" => \$name);
    }
    
    # Common Drive Resolution
    if ($sub eq 'files' || $sub eq '+upload' || ($command eq 'download' && $sub eq 'drive')) {
        unless ($drive_id) {
            if ($project_id) {
                $drive_id = $dooray->get_drive_id_by_project_id($project_id);
            } elsif ($wiki_id) {
                $drive_id = $dooray->get_drive_id_by_wiki_id($wiki_id);
            } else {
                my $def_drive   = $config->get('default_drive_id');
                my $def_project = $config->get('default_project_id');
                my $def_wiki    = $config->get('default_wiki_id');
                
                if ($def_drive) {
                    $drive_id = $def_drive;
                } elsif ($def_project) {
                    $drive_id = $dooray->get_drive_id_by_project_id($def_project);
                } elsif ($def_wiki) {
                    $drive_id = $dooray->get_drive_id_by_wiki_id($def_wiki);
                }
            }
        }
        $drive_id ||= $dooray->get_private_drive_id();
    }
    
    if ($command eq 'drive') {
        if ($upload_path) {
            die "Error: File not found: $upload_path\n" unless -e $upload_path;
            
            if ($json_meta && !$name) {
                my $context = join(' ', $json_meta, @ARGV);
                $context =~ s/\\(["'])/$1/g;
                if ($context =~ /name\W+([^"',}\s]+)/i) {
                    $name = $1;
                }
            }
            $name ||= (File::Spec->splitpath($upload_path))[2];
            
            printf "Uploading $upload_path to Drive as '%s'...\n", $name;
            my $result = $dooray->upload_file($drive_id, $upload_path, $name, $parent_id);
            print "Uploaded successfully! File ID: " . $result->{result}{id} . "\n";
        } elsif ($size) {
            my $data = $dooray->list_files($drive_id, size => $size);
            printf "%-25s | %-30s | %s\n", "ID", "Name", "Created At";
            print "-" x 80 . "\n";
            foreach my $file (@{$data->{result}}) {
                printf "%-25s | %-30s | %s\n", $file->{id}, substr($file->{name}, 0, 30), $file->{createdAt};
            }
        } else {
             print "Usage: delight drive files create --upload <path> [options]\n";
             print "       delight drive files list --size <count> [options]\n";
             print "       delight drive +upload <path>\n";
        }
    }
} elsif ($command eq 'page' || $command eq 'wiki') {
    my $sub = shift @ARGV;
    if ($sub eq 'create') {
        my ($subject, $content, $wiki_id, $project_id, $parent_id);
        GetOptions(
            "subject=s"   => \$subject,
            "content=s"   => \$content,
            "wiki-id=s"   => \$wiki_id,
            "project-id=s"=> \$project_id,
            "parent-id=s" => \$parent_id,
        );
        $subject ||= shift @ARGV;
        die "Usage: delight page create --subject <title> [--content <text>] [--parent-id <id>]\n" unless $subject;

        $wiki_id = resolve_wiki_id($wiki_id, undef, $project_id);
        die "Error: wiki-id not found. Provide --wiki-id or configure default_wiki_id.\n" unless $wiki_id;

        my $data = {
            subject => $subject,
            body => {
                mimeType => "text/x-markdown",
                content  => $content || "",
            },
        };
        $data->{parentPageId} = $parent_id if $parent_id;

        my $res = $dooray->create_wiki_page($wiki_id, $data);
        print "Wiki page created successfully! ID: " . $res->{result}{id} . "\n";
    } elsif ($sub eq 'update') {
        my ($page_id, $subject, $content, $wiki_id, $project_id);
        GetOptions(
            "page-id=s"   => \$page_id,
            "subject=s"   => \$subject,
            "content=s"   => \$content,
            "wiki-id=s"   => \$wiki_id,
            "project-id=s"=> \$project_id,
        );
        $page_id ||= shift @ARGV;
        die "Usage: delight page update --page-id <id> [--subject <title>] [--content <text>]\n" unless $page_id;

        $wiki_id = resolve_wiki_id($wiki_id, $page_id, $project_id);
        die "Error: wiki-id not found. Provide --wiki-id or configure default_wiki_id.\n" unless $wiki_id;

        unless ($subject) {
            my $current = $dooray->get_wiki_page_detail($wiki_id, $page_id);
            $subject = $current->{result}{subject};
        }

        my $data = { subject => $subject };
        if (defined $content) {
            $data->{body} = {
                mimeType => "text/x-markdown",
                content  => $content,
            };
        }

        my $res = $dooray->update_wiki_page($wiki_id, $page_id, $data);
        print "Wiki page updated successfully!\n";
    } elsif ($sub eq 'upload') {
        my ($page_id, $wiki_id, $project_id, $file);
        GetOptions(
            "page-id=s"    => \$page_id,
            "wiki-id=s"    => \$wiki_id,
            "project-id=s" => \$project_id,
            "file=s"       => \$file,
        );
        $page_id ||= shift @ARGV;
        die "Usage: delight page upload --page-id <id> [--file <path>]\n" unless $page_id;

        $wiki_id = resolve_wiki_id($wiki_id, $page_id, $project_id);
        die "Error: wiki-id not found. Provide --wiki-id or configure default_wiki_id.\n" unless $wiki_id;

        unless ($file) {
            my $base_dir = base_dir();
            $file = File::Spec->catfile($base_dir, "wiki_$wiki_id", "$page_id.md");
        }
        die "Error: File not found: $file\n" unless -f $file;

        open my $fh, '<:encoding(UTF-8)', $file or die "Could not open $file: $!\n";
        my $content = do { local $/; <$fh> };
        close $fh;

        my $current = $dooray->get_wiki_page_detail($wiki_id, $page_id);
        my $subject = $current->{result}{subject};

        $dooray->update_wiki_page($wiki_id, $page_id, {
            subject => $subject,
            body    => { mimeType => "text/x-markdown", content => $content },
        });
        print "Wiki page uploaded from $file\n";

        # If file is outside download dir, download to canonical location
        my $base_dir = base_dir();
        my $wiki_dir = File::Spec->catdir($base_dir, "wiki_$wiki_id");
        my $canonical = File::Spec->catfile($wiki_dir, "$page_id.md");
        if (File::Spec->rel2abs($file) ne File::Spec->rel2abs($canonical)) {
            make_path($wiki_dir) unless -d $wiki_dir;
            open my $out, '>:encoding(UTF-8)', $canonical or die "Could not open $canonical: $!\n";
            print $out $content;
            close $out;
            print "Downloaded to $canonical\n";
            print "Next time, edit and upload from: $canonical\n";
        }
    } elsif ($sub eq 'download') {
        my ($page_id, $wiki_id, $project_id);
        GetOptions(
            "page-id=s"    => \$page_id,
            "wiki-id=s"    => \$wiki_id,
            "project-id=s" => \$project_id,
        );
        $page_id ||= shift @ARGV;
        die "Usage: delight page download --page-id <id>\n" unless $page_id;

        $wiki_id = resolve_wiki_id($wiki_id, $page_id, $project_id);
        die "Error: wiki-id not found. Provide --wiki-id or configure default_wiki_id.\n" unless $wiki_id;

        my $detail = $dooray->get_wiki_page_detail($wiki_id, $page_id);
        my $data = $detail->{result};
        my $format = ($data->{body}{mimeType} || '') eq 'text/html' ? 'html' : 'md';
        my $content = $data->{body}{content} || '';

        my $base_dir = base_dir();
        my $wiki_dir = File::Spec->catdir($base_dir, "wiki_$wiki_id");
        make_path($wiki_dir) unless -d $wiki_dir;

        my $fpath = File::Spec->catfile($wiki_dir, "${page_id}.$format");
        open my $fh, '>:utf8', $fpath or die "Cannot write $fpath: $!\n";
        print $fh $content;
        close $fh;
        print "Saved to $fpath\n";
    } elsif ($sub eq 'delete') {
        my ($page_id, $wiki_id, $project_id);
        GetOptions(
            "page-id=s"    => \$page_id,
            "wiki-id=s"    => \$wiki_id,
            "project-id=s" => \$project_id,
        );
        $page_id ||= shift @ARGV;
        die "Usage: delight page delete --page-id <id>\n" unless $page_id;

        $wiki_id = resolve_wiki_id($wiki_id, $page_id, $project_id);
        die "Error: wiki-id not found. Provide --wiki-id or configure default_wiki_id.\n" unless $wiki_id;

        my $current = $dooray->get_wiki_page_detail($wiki_id, $page_id);
        my $result = $current->{result};
        my $subject = $result->{subject};
        $subject = "#TBD $subject" unless $subject =~ /^#TBD /;
        $dooray->update_wiki_page($wiki_id, $page_id, {
            subject => $subject,
            body    => $result->{body},
        });
        print "Wiki page marked as deleted: $subject\n";

        # Remove local copy if exists
        my $base_dir = base_dir();
        my $wiki_dir = File::Spec->catdir($base_dir, "wiki_$wiki_id");
        for my $ext ('md', 'html') {
            my $fpath = File::Spec->catfile($wiki_dir, "$page_id.$ext");
            if (-f $fpath) {
                unlink $fpath;
                print "Removed local copy: $fpath\n";
            }
        }
    } elsif ($sub eq 'undelete') {
        my ($page_id, $wiki_id, $project_id);
        GetOptions(
            "page-id=s"    => \$page_id,
            "wiki-id=s"    => \$wiki_id,
            "project-id=s" => \$project_id,
        );
        $page_id ||= shift @ARGV;
        die "Usage: delight page undelete --page-id <id>\n" unless $page_id;

        $wiki_id = resolve_wiki_id($wiki_id, $page_id, $project_id);
        die "Error: wiki-id not found. Provide --wiki-id or configure default_wiki_id.\n" unless $wiki_id;

        my $current = $dooray->get_wiki_page_detail($wiki_id, $page_id);
        my $result = $current->{result};
        my $subject = $result->{subject};
        $subject =~ s/^#TBD\s*//;
        $dooray->update_wiki_page($wiki_id, $page_id, {
            subject => $subject,
            body    => $result->{body},
        });
        print "Wiki page undeleted: $subject\n";

        # Download if local copy is not available
        my $base_dir = base_dir();
        my $wiki_dir = File::Spec->catdir($base_dir, "wiki_$wiki_id");
        my $fpath = File::Spec->catfile($wiki_dir, "$page_id.md");
        unless (-f $fpath) {
            make_path($wiki_dir) unless -d $wiki_dir;
            my $body_content = $result->{body}{content} || '';
            open my $fh, '>:encoding(UTF-8)', $fpath or die "Could not open $fpath: $!\n";
            print $fh "# $subject\n\n$body_content\n";
            close $fh;
            print "Downloaded to $fpath\n";
        }
    }
} elsif ($command eq 'task' || $command eq 'post') {
    my $sub = shift @ARGV;
    if ($sub eq 'create') {
        my ($subject, $content, $project_id);
        GetOptions(
            "subject=s"    => \$subject,
            "content=s"    => \$content,
            "project-id=s" => \$project_id,
        );
        $subject ||= shift @ARGV;
        die "Usage: delight task create --subject <title> [--content <text>] [--project-id <id>]\n" unless $subject;
        $project_id ||= $config->get('default_project_id');
        die "Error: project-id required. Provide --project-id or configure default_project_id.\n" unless $project_id;

        my $my_id = $dooray->whoami()->{result}{id};
        my $data = {
            subject => $subject,
            body    => { mimeType => "text/x-markdown", content => $content || "" },
            users   => { to => [{ type => "member", member => { organizationMemberId => $my_id } }] },
        };
        my $res = $dooray->create_post($project_id, $data);
        print "Task created successfully! ID: " . $res->{result}{id} . "\n";
    } elsif ($sub eq 'list') {
        my ($project_id, $size);
        GetOptions(
            "project-id=s" => \$project_id,
            "size=i"       => \$size,
        );
        $project_id ||= shift @ARGV || $config->get('default_project_id');
        die "Usage: delight task list [--project-id <id>] [--size <n>]\n" unless $project_id;
        my $data = $dooray->list_posts_paginated($project_id, 0, $size || 100);
        foreach my $post (@{$data->{result}}) {
            printf "%-25s | %s\n", $post->{id}, $post->{subject};
        }
    } elsif ($sub eq 'delete') {
        my ($post_id, $project_id);
        GetOptions(
            "task-id=s"    => \$post_id,
            "post-id=s"    => \$post_id,
            "project-id=s" => \$project_id,
        );
        $post_id ||= shift @ARGV;
        die "Usage: delight task delete --task-id <id> [--project-id <id>]\n" unless $post_id;
        $project_id = resolve_project_id($project_id, $post_id);
        die "Error: project-id not found.\n" unless $project_id;

        my $current = $dooray->get_post_detail($project_id, $post_id);
        my $subject = $current->{result}{subject};
        $subject = "#TBD $subject" unless $subject =~ /^#TBD /;
        $dooray->update_post($project_id, $post_id, { subject => $subject });
        print "Task marked as deleted: $subject\n";

        # Remove local copy if exists
        my $base_dir = base_dir();
        my $task_dir = File::Spec->catdir($base_dir, "project_$project_id");
        for my $ext ('md', 'html') {
            my $fpath = File::Spec->catfile($task_dir, "$post_id.$ext");
            if (-f $fpath) {
                unlink $fpath;
                print "Removed local copy: $fpath\n";
            }
        }
    } elsif ($sub eq 'undelete') {
        my ($post_id, $project_id);
        GetOptions(
            "task-id=s"    => \$post_id,
            "post-id=s"    => \$post_id,
            "project-id=s" => \$project_id,
        );
        $post_id ||= shift @ARGV;
        die "Usage: delight task undelete --task-id <id> [--project-id <id>]\n" unless $post_id;
        $project_id = resolve_project_id($project_id, $post_id);
        die "Error: project-id not found.\n" unless $project_id;

        my $current = $dooray->get_post_detail($project_id, $post_id);
        my $subject = $current->{result}{subject};
        $subject =~ s/^#TBD\s*//;
        $dooray->update_post($project_id, $post_id, { subject => $subject });
        print "Task undeleted: $subject\n";

        # Download if local copy is not available
        my $base_dir = base_dir();
        my $task_dir = File::Spec->catdir($base_dir, "project_$project_id");
        my $fpath = File::Spec->catfile($task_dir, "$post_id.md");
        unless (-f $fpath) {
            make_path($task_dir) unless -d $task_dir;
            my $body_content = $current->{result}{body}{content} || '';
            open my $fh, '>:encoding(UTF-8)', $fpath or die "Could not open $fpath: $!\n";
            print $fh $body_content;
            close $fh;
            print "Downloaded to $fpath\n";
        }
    } elsif ($sub eq 'download') {
        my ($task_id, $project_id);
        GetOptions(
            "task-id=s"    => \$task_id,
            "post-id=s"    => \$task_id,
            "project-id=s" => \$project_id,
        );
        $task_id ||= shift @ARGV;
        die "Usage: delight task download --task-id <id> [--project-id <id>]\n" unless $task_id;
        $project_id = resolve_project_id($project_id, $task_id);
        die "Error: project-id not found.\n" unless $project_id;

        my $detail = $dooray->get_post_detail($project_id, $task_id);
        my $data = $detail->{result};
        my $format = ($data->{body}{mimeType} || '') eq 'text/html' ? 'html' : 'md';
        my $content = $data->{body}{content} || '';

        my $base_dir = base_dir();
        my $task_dir = File::Spec->catdir($base_dir, "project_$project_id");
        make_path($task_dir) unless -d $task_dir;

        my $fpath = File::Spec->catfile($task_dir, "${task_id}.$format");
        open my $fh, '>:utf8', $fpath or die "Cannot write $fpath: $!\n";
        print $fh $content;
        close $fh;
        print "Saved to $fpath\n";
    } elsif ($sub eq 'upload') {
        my ($task_id, $project_id, $file);
        GetOptions(
            "task-id=s"    => \$task_id,
            "post-id=s"    => \$task_id,
            "project-id=s" => \$project_id,
            "file=s"       => \$file,
        );
        $task_id ||= shift @ARGV;
        die "Usage: delight task upload --task-id <id> [--file <path>] [--project-id <id>]\n" unless $task_id;
        $project_id = resolve_project_id($project_id, $task_id);
        die "Error: project-id not found.\n" unless $project_id;

        unless ($file) {
            my $base_dir = base_dir();
            $file = File::Spec->catfile($base_dir, "project_$project_id", "$task_id.md");
        }
        die "Error: File not found: $file\n" unless -f $file;

        open my $fh, '<:encoding(UTF-8)', $file or die "Could not open $file: $!\n";
        my $content = do { local $/; <$fh> };
        close $fh;

        my $current = $dooray->get_post_detail($project_id, $task_id);
        my $subject = $current->{result}{subject};

        $dooray->update_post($project_id, $task_id, {
            subject => $subject,
            body    => { mimeType => "text/x-markdown", content => $content },
        });
        print "Task uploaded from $file\n";

        # If file is outside download dir, copy to canonical location
        my $base_dir = base_dir();
        my $task_dir = File::Spec->catdir($base_dir, "project_$project_id");
        my $canonical = File::Spec->catfile($task_dir, "$task_id.md");
        if (File::Spec->rel2abs($file) ne File::Spec->rel2abs($canonical)) {
            make_path($task_dir) unless -d $task_dir;
            open my $out, '>:encoding(UTF-8)', $canonical or die "Could not open $canonical: $!\n";
            print $out $content;
            close $out;
            print "Downloaded to $canonical\n";
            print "Next time, edit and upload from: $canonical\n";
        }
    }
} elsif ($command eq 'download') {
    my $sub = shift @ARGV;
    my ($reset_cache, $with_attachments, $project_id, $wiki_id, $drive_id, $delay, $page_id);
    $delay = 20; # Ensure default is 20s as requested
    GetOptions(
        "reset-cache"      => \$reset_cache,
        "with-attachments" => \$with_attachments,
        "project-id=s"     => \$project_id,
        "wiki-id=s"        => \$wiki_id,
        "drive-id=s"       => \$drive_id,
        "delay=i"          => \$delay,
        "page-id=s"        => \$page_id,
    );
    
    $project_id ||= $config->get('default_project_id');
    $wiki_id    ||= $config->get('default_wiki_id');
    $drive_id   ||= $config->get('default_drive_id');

    $dooray->{delay} = $delay;

    my $cache_file = '.delight_download_cache.sdbm';
    if ($reset_cache) {
        unlink "${cache_file}.dir" if -e "${cache_file}.dir";
        unlink "${cache_file}.pag" if -e "${cache_file}.pag";
        print "Cache reset.\n";
    }
    
    my %cache;
    tie(%cache, 'SDBM_File', $cache_file, O_RDWR|O_CREAT, 0640) or die "Could not open DB file: $!\n";
    
    my $base_dir = base_dir();
    
    make_path($base_dir) unless -d $base_dir;
    
    my sub sanitize_filename {
        my ($name) = @_;
        $name =~ s/[\\\/:\*\?"<>\|]/_/g;
        $name =~ s/^\s+//;
        $name =~ s/\s+$//;
        return $name || 'untitled';
    }

    my sub slugify {
        my ($text) = @_;
        $text = lc($text);
        $text =~ s/[^a-z0-9\x{ac00}-\x{d7af}]+/-/gi; # Keep alphanumeric and Korean
        $text =~ s/^-+|-+$//g;
        return $text || 'page';
    }

    if ($sub eq 'tasks') {
        my @projects;
        if ($project_id) {
            push @projects, { id => $project_id, code => $project_id };
        } else {
            my $res = $dooray->list_projects();
            my $all_projects = $res->{result} || [];
            
            print "Available Projects:\n";
            print "  [0] All Projects\n";
            my $idx = 1;
            foreach my $p (@$all_projects) {
                my $desc = $p->{description} ? " - $p->{description}" : "";
                printf "  [%d] %s%s\n", $idx++, $p->{code}, $desc;
            }
            
            print "\nSelect a project to download (0-" . scalar(@$all_projects) . ") [0]: ";
            my $sel = <STDIN>;
            chomp $sel;
            
            if ($sel && $sel =~ /^\d+$/ && $sel > 0 && $sel <= scalar(@$all_projects)) {
                push @projects, $all_projects->[$sel - 1];
            } else {
                @projects = @$all_projects;
                print "Selected: All Projects\n";
            }
        }
        
        foreach my $proj (@projects) {
            my $pid = $proj->{id};
            my $task_dir = File::Spec->catdir($base_dir, "project_$pid");
            make_path($task_dir) unless -d $task_dir;
            print "Fetching tasks for project $pid...\n";
            my $page = 0;
            my $has_more = 1;
            while ($has_more) {
                my $res = eval { $dooray->list_posts_paginated($pid, $page, 100) };
                if ($@ || !$res->{result}) {
                    warn "Error fetching posts for $pid: $@\n";
                    last;
                }
                my $posts = $res->{result} || [];
                $has_more = @$posts == 100;
                $page++;
                
                foreach my $p (@$posts) {
                    my $post_id = $p->{id};
                    if ($cache{"task_$post_id"}) {
                        next;
                    }
                    
                    print "Downloading task $post_id: $p->{subject}\n";
                    my $detail = eval { $dooray->get_post_detail($pid, $post_id) };
                    next if $@ || !$detail->{result};
                    
                    my $data = $detail->{result};
                    my $format = ($data->{body}{mimeType} || '') eq 'text/html' ? 'html' : 'md';
                    my $content = $data->{body}{content} || '';
                    
                    my $slug = slugify($data->{subject} || 'task');
                    my $fname = "${post_id}-$slug.$format";
                    my $fpath = File::Spec->catfile($task_dir, $fname);
                    
                    open my $fh, '>:utf8', $fpath or warn "Cannot write $fpath: $!";
                    print $fh $content;
                    close $fh;
                    
                    if ($delay) {
                        my $rand_delay = int(rand(9)) + 2; # 2 to 10
                        print "Waiting $rand_delay seconds after downloading...\n";
                        sleep $rand_delay;
                    }

                    if ($with_attachments) {
                        my $files_res = eval { $dooray->get_post_files($pid, $post_id) };
                        if (!$@ && $files_res->{result} && @{$files_res->{result}}) {
                            my $att_dir = File::Spec->catdir($task_dir, "${post_id}_attachments");
                            make_path($att_dir);
                            foreach my $f (@{$files_res->{result}}) {
                                my $f_id = $f->{id};
                                my $dl_url = $dooray->{domain} . "/project/v1/projects/$pid/posts/$post_id/files/$f_id?media=raw";
                                my $f_save = File::Spec->catfile($att_dir, sanitize_filename($f->{name}));
                                eval { $dooray->download_file($dl_url, $f_save) };
                                if ($@) {
                                    warn "Failed to download $f->{name}: $@\n";
                                } else {
                                    if ($delay) {
                                        my $rand_delay = int(rand(9)) + 2;
                                        print "Waiting $rand_delay seconds after downloading...\n";
                                        sleep $rand_delay;
                                    }
                                }
                            }
                        }
                    }
                    
                    $cache{"task_$post_id"} = 1;
                }
            }
        }
    } elsif ($sub eq 'wiki') {
        my @wikis;
        if ($wiki_id) {
            push @wikis, { id => $wiki_id };
        } elsif ($project_id) {
            eval {
                my $resolved_wiki_id = $dooray->get_wiki_id_by_project_id($project_id);
                push @wikis, { id => $resolved_wiki_id };
            };
            if ($@) {
                warn "Failed to resolve wiki-id from project-id $project_id: $@\n";
            }
        } else {
            my $res = eval { $dooray->list_wikis() };
            if (!$@ && $res->{result}) {
                @wikis = @{$res->{result} || []};
            } else {
                warn "Failed to access wikis: $@\n";
            }
        }
        
        my %wiki_tree;   # parent_id -> [child_id, ...]
        my %page_titles; # id -> subject

        foreach my $w (@wikis) {
            my $wid = $w->{id};
            my $wiki_dir = File::Spec->catdir($base_dir, "wiki_$wid");
            make_path($wiki_dir) unless -d $wiki_dir;
            
            if ($page_id) {
                print "Downloading single wiki page $page_id from wiki $wid...\n";
                my $detail = eval { $dooray->get_wiki_page_detail($wid, $page_id) };
                if ($@ || !$detail->{result}) {
                    warn "Error fetching wiki page $page_id: $@\n";
                    next;
                }
                my $data = $detail->{result};
                my $subject = $data->{subject} || 'No Title';
                
                my $format = ($data->{body}{mimeType} || '') eq 'text/html' ? 'html' : 'md';
                my $content = $data->{body}{content} || '';
                
                my $fname = "${page_id}.$format";
                my $fpath = File::Spec->catfile($wiki_dir, $fname);
                
                open my $fh, '>:utf8', $fpath or warn "Cannot write $fpath: $!";
                print $fh $content;
                close $fh;
                print "Saved to $fpath\n";
                next;
            }

            print "Fetching all wiki pages for wiki $wid...\n";
            
            my @parent_queue = (undef); # Start with root pages
            while (@parent_queue) {
                my $current_parent = shift @parent_queue;
                my $page = 0;
                my $has_more = 1;
                while ($has_more) {
                    my $res = eval { $dooray->list_wiki_pages_paginated($wid, $page, 100, parentPageId => $current_parent) };
                    if ($@ || !$res->{result}) {
                        warn "Error fetching wikis for $wid (parent: $current_parent): $@\n";
                        last;
                    }
                    my $pages = $res->{result} || [];
                    $has_more = @$pages == 100;
                    $page++;
                    
                    foreach my $p (@$pages) {
                        my $page_id = $p->{id};
                        my $subject = $p->{subject} || 'No Title';
                        
                        # Build tree structure
                        my $pid_key = $current_parent || 'ROOT';
                        push @{$wiki_tree{$pid_key}}, $page_id;
                        $page_titles{$page_id} = $subject;

                        # Add to queue to fetch its children later
                        push @parent_queue, $page_id;

                        if ($cache{"wiki_$page_id"}) {
                            next;
                        }
                        
                        print "Downloading wiki page $page_id: $subject\n";
                        my $detail = eval { $dooray->get_wiki_page_detail($wid, $page_id) };
                        next if $@ || !$detail->{result};
                        
                        my $data = $detail->{result};
                        my $format = ($data->{body}{mimeType} || '') eq 'text/html' ? 'html' : 'md';
                        my $content = $data->{body}{content} || '';
                        
                        my $fname = "${page_id}.$format";
                        my $fpath = File::Spec->catfile($wiki_dir, $fname);
                        
                        open my $fh, '>:utf8', $fpath or warn "Cannot write $fpath: $!";
                        print $fh $content;
                        close $fh;

                        if ($delay) {
                            my $rand_delay = int(rand(9)) + 2;
                            print "Waiting $rand_delay seconds after downloading...\n";
                            sleep $rand_delay;
                        }
                        
                        if ($with_attachments) {
                            my $files_res = eval { $dooray->get_wiki_page_files($wid, $page_id) };
                            if (!$@ && $files_res->{result} && @{$files_res->{result}}) {
                                my $att_dir = File::Spec->catdir($wiki_dir, "${page_id}_attachments");
                                make_path($att_dir);
                                foreach my $f (@{$files_res->{result}}) {
                                    my $f_id = $f->{id} || $f->{attachFileId};
                                    next unless $f_id;
                                    my $dl_url = $dooray->{domain} . "/wiki/v1/wikis/$wid/pages/$page_id/files/$f_id";
                                    my $f_save = File::Spec->catfile($att_dir, sanitize_filename($f->{name} || $f_id));
                                    eval { $dooray->download_file($dl_url, $f_save) };
                                    if ($@) {
                                        warn "Failed to download $f->{name}: $@\n";
                                    } else {
                                        if ($delay) {
                                            my $rand_delay = int(rand(9)) + 2;
                                            print "Waiting $rand_delay seconds after downloading...\n";
                                            sleep $rand_delay;
                                        }
                                    }
                                }
                            }
                        }
                        $cache{"wiki_$page_id"} = 1;
                    }
                }
            }

            # Generate Hierarchy Map
            my $map_path = File::Spec->catfile($base_dir, "WIKI_MAP_$wid.md");
            open my $mfh, '>:utf8', $map_path or warn "Cannot write map $map_path: $!";
            print $mfh "# Wiki Hierarchy Map ($wid)\n\n";

            my $render_sub;
            $render_sub = sub {
                my ($pid, $depth) = @_;
                foreach my $cid (@{$wiki_tree{$pid} || []}) {
                    my $indent = "  " x $depth;
                    my $bullet = ($depth == 0) ? "" : "- ";
                    printf $mfh "%s%s%s (%s.md)\n", $indent, $bullet, $page_titles{$cid}, $cid;
                    $render_sub->($cid, $depth + 1);
                }
            };
            $render_sub->('ROOT', 0);
            close $mfh;
            print "Wiki map saved to $map_path\n";
        }
    } elsif ($sub eq 'drive') {
        my @drives;
        if ($drive_id) {
            push @drives, { id => $drive_id };
        } else {
            my $res = eval { $dooray->list_drives() };
            if (!$@ && $res->{result}) {
                @drives = @{$res->{result}};
            } else {
                warn "Failed to access org drives, falling back to private drive.\n";
                @drives = ( { id => eval { $dooray->get_private_drive_id() } } );
            }
        }
        
        my $drv_dir = File::Spec->catdir($base_dir, 'drive');
        make_path($drv_dir) unless -d $drv_dir;
        
        foreach my $d (@drives) {
            my $did = $d->{id};
            next unless $did;
            print "Fetching files for drive $did...\n";
            my $page = 0;
            my $has_more = 1;
            while ($has_more) {
                my $res = eval { $dooray->list_files($did, size => 100, page => $page, type => 'file') };
                if ($@ || !$res->{result}) {
                    warn "Error fetching files for drive $did: $@\n";
                    last;
                }
                my $files = $res->{result} || [];
                $has_more = @$files == 100;
                $page++;
                
                foreach my $f (@$files) {
                    my $file_id = $f->{id};
                    if ($cache{"drive_$file_id"}) {
                        next;
                    }
                    
                    print "Downloading drive file $file_id: $f->{name}\n";
                    my $dl_url = $dooray->{domain} . "/drive/v1/drives/$did/files/$file_id?media=raw";
                    my $f_save = File::Spec->catfile($drv_dir, sanitize_filename($f->{name}) . "_$file_id");
                    eval { $dooray->download_file($dl_url, $f_save) };
                    if ($@) {
                        warn "Failed to download $f->{name}: $@\n";
                    } else {
                        $cache{"drive_$file_id"} = 1;
                        if ($delay) {
                            my $rand_delay = int(rand(9)) + 2;
                            print "Waiting $rand_delay seconds after downloading...\n";
                            sleep $rand_delay;
                        }
                    }
                }
            }
        }
    } else {
        print "Usage: delight download tasks|wiki|drive [--reset-cache] [--with-attachments] [--project-id <id>] [--wiki-id <id>] [--drive-id <id>]\n";
    }
    untie %cache;
} elsif ($command eq 'upload') {
    my $sub = shift @ARGV;
    my ($reset_cache, $project_id, $wiki_id, $drive_id, $parent_id, $delay);
    $delay = 1; # Default enable delay
    GetOptions(
        "reset-cache"  => \$reset_cache,
        "project-id=s" => \$project_id,
        "wiki-id=s"    => \$wiki_id,
        "drive-id=s"   => \$drive_id,
        "parent-id=s"  => \$parent_id,
        "delay=i"      => \$delay,
    );
    
    $project_id ||= $config->get('default_project_id');
    $wiki_id    ||= $config->get('default_wiki_id');
    $drive_id   ||= $config->get('default_drive_id');

    my $cache_file = '.delight_upload_cache.sdbm';
    if ($reset_cache) {
        unlink "${cache_file}.dir" if -e "${cache_file}.dir";
        unlink "${cache_file}.pag" if -e "${cache_file}.pag";
        print "Cache reset.\n";
    }
    
    my %cache;
    tie(%cache, 'SDBM_File', $cache_file, O_RDWR|O_CREAT, 0640) or die "Could not open DB file: $!\n";
    
    my $up_dir = $config->get('upload_dir') || File::Spec->catdir(File::HomeDir->my_home, 'delight_upload');
    make_path($up_dir) unless -d $up_dir;

    if ($sub eq 'drive') {
        unless ($drive_id) {
            if ($project_id) {
                $drive_id = $dooray->get_drive_id_by_project_id($project_id);
            } elsif ($wiki_id) {
                $drive_id = $dooray->get_drive_id_by_wiki_id($wiki_id);
            }
        }
        $drive_id ||= $dooray->get_private_drive_id();
        
        print "Syncing files from $up_dir to Drive $drive_id...\n";
        
        opendir my $dh, $up_dir or die "Cannot open $up_dir: $!";
        my @files = sort grep { -f File::Spec->catfile($up_dir, $_) } readdir $dh;
        closedir $dh;
        
        foreach my $filename (@files) {
            my $fpath = File::Spec->catfile($up_dir, $filename);
            my @st = stat($fpath);
            my $mtime = $st[9];
            my $size  = $st[7];
            
            my $cache_key = "${filename}_${size}_${mtime}";
            if ($cache{$cache_key}) {
                # print "Skipping $filename (already uploaded)\n";
                next;
            }
            
            my $existing_id = $dooray->find_file_by_name($drive_id, $filename, $parent_id);
            
            my $res;
            if ($existing_id) {
                print "Updating $filename (ID: $existing_id)...\n";
                $res = eval { $dooray->update_file($drive_id, $existing_id, $fpath, $filename) };
            } else {
                print "Uploading $filename...\n";
                $res = eval { $dooray->upload_file($drive_id, $fpath, $filename, $parent_id) };
            }

            if ($@) {
                warn "Failed to upload/update $filename: $@\n";
            } else {
                my $new_id = $res->{result}{id};
                $cache{$cache_key} = $new_id;
                print "Sync $filename successfully (ID: $new_id)\n";
                
                if ($delay) {
                    my $rand_delay = int(rand(9)) + 2; # 2 to 10
                    print "Waiting $rand_delay seconds after uploading...\n";
                    sleep $rand_delay;
                }
            }
        }
    } else {
        print "Usage: delight upload drive [--reset-cache] [--project-id <id>] [--wiki-id <id>] [--drive-id <id>] [--parent-id <id>]\n";
    }
    untie %cache;
} elsif ($command eq 'config') {
    my $key = shift @ARGV;
    my $val = shift @ARGV;
    if ($key && $val) {
        $config->set($key, $val);
        $config->save();
        print "Set $key to $val\n";
    } else {
        print "Usage: delight config <key> <value>\n";
    }
} else {
    print "Usage: delight <command> [args]\n";
    print "Commands: whoami, project, calendar, drive, page, task, download, upload, config\n";
}
