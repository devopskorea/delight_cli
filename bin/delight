#!/usr/bin/env perl

use strict;
use warnings;
# Installed via Makefile.PL, modules should be in @INC
use Delight::Config;
use Delight::Dooray;
use Getopt::Long;
use JSON::PP;
use HTTP::Tiny;
use File::Spec;
use File::Path qw(make_path);
use Encode qw(encode_utf8 decode_utf8);
use POSIX qw(strftime);
use Time::Piece;
use Fcntl;
use SDBM_File;

sub _home { return $ENV{HOME} || (getpwuid($<))[7] || '.'; }

# Ensure UTF-8 for terminal and command-line arguments
use open qw(:std :utf8);
use utf8;
use IPC::Open2;
binmode STDOUT, ":utf8";
@ARGV = map { decode_utf8($_) } @ARGV;
binmode STDERR, ":utf8";

my $config = Delight::Config->new();
my $dooray = Delight::Dooray->new(
    token  => $config->get('token'),
    domain => $config->get('domain'),
);

my $command = shift @ARGV || 'help';

# --- Helpers ---

sub base_dir {
    $config->get('download_dir') || File::Spec->catdir(_home(), 'delight');
}

sub resolve_wiki_id {
    my ($wiki_id, $page_id, $project_id) = @_;
    return $wiki_id if $wiki_id;
    if ($page_id) {
        my $info = eval { $dooray->get_wiki_page($page_id) };
        return $info->{result}{wikiId} if $info && $info->{result}{wikiId};
    }
    $wiki_id = $config->get('default_wiki_id');
    return $wiki_id if $wiki_id;
    $project_id ||= $config->get('default_project_id');
    if ($project_id) {
        return eval { $dooray->get_wiki_id_by_project_id($project_id) };
    }
    return undef;
}

sub resolve_project_id {
    my ($project_id, $task_id) = @_;
    return $project_id if $project_id;
    if ($task_id) {
        my $info = eval { $dooray->get_post($task_id) };
        return $info->{result}{project}{id} if $info && $info->{result}{project};
    }
    return $config->get('default_project_id');
}

sub _format_task {
    my ($post, $fields) = @_;
    my @parts = ($post->{id});
    for my $f (@$fields) {
        if ($f eq 'title') {
            push @parts, $post->{subject} || '';
        } elsif ($f eq 'status') {
            push @parts, $post->{workflow}{name} || '';
        } elsif ($f eq 'assignee') {
            my @names;
            for my $u (@{$post->{users}{to} || []}) {
                if ($u->{type} eq 'member') {
                    push @names, $u->{member}{name} || $u->{member}{organizationMemberId} || '';
                } elsif ($u->{type} eq 'group') {
                    for my $m (@{$u->{group}{members} || []}) {
                        push @names, $m->{name} || $m->{organizationMemberId} || '';
                    }
                }
            }
            push @parts, join(', ', @names) || '';
        } elsif ($f eq 'priority') {
            push @parts, $post->{priority} || '';
        } elsif ($f eq 'duedate') {
            push @parts, $post->{dueDate} || '';
        } elsif ($f eq 'tags') {
            my @tag_names = map { $_->{name} || '' } @{$post->{tags} || []};
            push @parts, join(', ', @tag_names) || '';
        } elsif ($f eq 'tasknumber') {
            push @parts, $post->{taskNumber} || '';
        }
    }
    return join(' | ', @parts);
}

sub _parse_link_target {
    my ($arg) = @_;
    if ($arg =~ m{^https?://[^/]+/project/(tasks|pages)/(\d+)}) {
        return { type => ($1 eq 'tasks' ? 'task' : 'page'), id => $2 };
    }
    if ($arg =~ /^(task|page):(\d+)$/) {
        return { type => $1, id => $2 };
    }
    die "Invalid link target: $arg (use URL or task:<id>/page:<id>)\n";
}

sub _add_reference {
    my ($body, $ref_line, $at_start) = @_;
    $body //= '';

    my @lines = split /\n/, $body, -1;
    my $heading_idx;
    for my $i (0..$#lines) {
        if ($lines[$i] =~ /^#{1,6}\s*참고\s*$/) {
            $heading_idx = $i;
            last;
        }
    }

    if (defined $heading_idx) {
        my $section_end = scalar @lines;
        for my $i (($heading_idx + 1)..$#lines) {
            if ($lines[$i] =~ /^#{1,6}\s/) {
                $section_end = $i;
                last;
            }
        }
        my $insert_at = $section_end;
        for (my $j = $section_end - 1; $j > $heading_idx; $j--) {
            if ($lines[$j] =~ /\S/) {
                $insert_at = $j + 1;
                last;
            }
        }
        splice(@lines, $insert_at, 0, $ref_line);
        return join("\n", @lines);
    }

    my $section = "## 참고\n\n$ref_line\n";
    if ($at_start) {
        return $body eq '' ? $section : "$section\n$body";
    }
    my $sep = ($body eq '' || $body =~ /\n\n$/) ? '' : ($body =~ /\n$/ ? "\n" : "\n\n");
    return $body . $sep . $section;
}

sub _llm_complete {
    my ($prompt) = @_;
    my $cmd = $config->get('llm_command');
    my $url = $config->get('llm_api_url');
    my $key = $config->get('llm_api_key');

    if ($cmd) {
        my $pid = open2(my $out, my $in, $cmd) or die "Cannot run llm_command: $!\n";
        binmode $in,  ':encoding(UTF-8)';
        binmode $out, ':encoding(UTF-8)';
        print $in $prompt;
        close $in;
        my $reply = do { local $/; <$out> };
        close $out;
        waitpid($pid, 0);
        die "llm_command exited with status " . ($? >> 8) . "\n" if $? >> 8;
        return $reply // '';
    }
    if ($url && $key) {
        my $model = $config->get('llm_model') || 'gpt-4o-mini';
        my $payload = {
            model    => $model,
            messages => [ { role => 'user', content => $prompt } ],
        };
        my $ua = HTTP::Tiny->new(timeout => 120);
        my $res = $ua->request('POST', $url, {
            headers => {
                'Content-Type'  => 'application/json',
                'Authorization' => "Bearer $key",
            },
            content => JSON::PP->new->utf8->encode($payload),
        });
        die "llm_api error: $res->{status} $res->{reason}\n" . ($res->{content} // '') . "\n" unless $res->{success};
        # HTTP::Tiny returns raw bytes — server sends UTF-8 JSON, decode in one step.
        my $data = JSON::PP->new->utf8->decode($res->{content});
        return $data->{choices}[0]{message}{content} // '';
    }
    die "No LLM backend configured. Set llm_command (e.g. 'claude -p') or llm_api_url + llm_api_key.\n";
}

sub _wiki_meta {
    my ($wiki_id) = @_;
    for my $w (@{$dooray->list_wikis()->{result} || []}) {
        return ($w->{home}{pageId}, $w->{project}{id}, $w->{name}) if $w->{id} eq $wiki_id;
    }
    return (undef, undef, undef);
}

sub _walk_wiki_pages {
    my ($wiki_id, $parent_id, $depth) = @_;
    $depth //= 0;
    my @result;
    my $page = 0;
    while (1) {
        my $r = $dooray->list_wiki_pages_paginated($wiki_id, $page, 100, parentPageId => $parent_id);
        my $items = $r->{result} || [];
        last unless @$items;
        for my $p (@$items) {
            push @result, { %$p, _depth => $depth };
            push @result, _walk_wiki_pages($wiki_id, $p->{id}, $depth + 1);
        }
        last if scalar(@$items) < 100;
        $page++;
    }
    return @result;
}

sub _load_wiki_pages_with_body {
    my ($wiki_id, $home_id) = @_;
    my @pages = _walk_wiki_pages($wiki_id, $home_id);
    for my $p (@pages) {
        my $d = $dooray->get_wiki_page_detail($wiki_id, $p->{id});
        $p->{body} = $d->{result}{body}{content} // '';
        $p->{subject} = $d->{result}{subject} // $p->{subject};
    }
    return @pages;
}

if ($command eq 'whoami') {
    my $data = $dooray->whoami();
    print "Name: " . $data->{result}{name} . "\n";
    print "Email: " . $data->{result}{externalEmailAddress} . "\n";
} elsif ($command eq 'project') {
    my $sub = shift @ARGV;
    if ($sub eq 'list') {
        my $data = $dooray->list_projects();
        foreach my $p (@{$data->{result}}) {
            printf "%-25s | %s\n", $p->{id}, $p->{code};
        }
    } elsif ($sub eq 'settings') {
        my $project_id;
        GetOptions("project-id=s" => \$project_id);
        $project_id ||= shift @ARGV || $config->get('default_project_id');
        die "Usage: delight project settings [--project-id <id>]\n" unless $project_id;

        my $workflows = $dooray->list_workflows($project_id);
        my $milestones = $dooray->list_milestones($project_id);
        my $tags = $dooray->list_tags($project_id);
        my $members = $dooray->list_project_members($project_id);

        my $output = "# Project Settings ($project_id)\n\n";

        $output .= "## Status\n\n";
        $output .= sprintf "%-25s | %-15s | %s\n", "ID", "Class", "Name";
        $output .= "-" x 60 . "\n";
        for my $w (@{$workflows->{result} || []}) {
            $output .= sprintf "%-25s | %-15s | %s\n", $w->{id}, $w->{class}, $w->{name};
        }

        $output .= "\n## Phases\n\n";
        $output .= sprintf "%-25s | %-15s | %s\n", "ID", "Status", "Name";
        $output .= "-" x 60 . "\n";
        for my $m (@{$milestones->{result} || []}) {
            $output .= sprintf "%-25s | %-15s | %s\n", $m->{id}, $m->{status} || '', $m->{name};
        }

        $output .= "\n## Tags\n\n";
        $output .= sprintf "%-25s | %s\n", "ID", "Name";
        $output .= "-" x 40 . "\n";
        for my $t (@{$tags->{result} || []}) {
            $output .= sprintf "%-25s | %s\n", $t->{id}, $t->{name};
        }

        $output .= "\n## Members\n\n";
        $output .= sprintf "%-25s | %-15s | %s\n", "ID", "Role", "Name";
        $output .= "-" x 60 . "\n";
        for my $m (@{$members->{result} || []}) {
            my $id = $m->{organizationMemberId} || '';
            my $role = $m->{role} || '';
            my $name = '';
            if ($id) {
                my $info = eval { $dooray->request('GET', "/common/v1/members/$id") };
                $name = $info->{result}{name} || '' if $info;
            }
            $output .= sprintf "%-25s | %-15s | %s\n", $id, $role, $name;
        }

        print $output;

        # Save to file
        my $base_dir = base_dir();
        my $proj_dir = File::Spec->catdir($base_dir, "project_$project_id");
        make_path($proj_dir) unless -d $proj_dir;
        my $fpath = File::Spec->catfile($proj_dir, "settings.md");
        open my $fh, '>:encoding(UTF-8)', $fpath or die "Could not open $fpath: $!\n";
        print $fh $output;
        close $fh;
        print "\nSaved to $fpath\n";
    }
} elsif ($command eq 'calendar') {
    my $sub = shift @ARGV;
    if ($sub eq '+agenda') {
        my ($today, $week, $days, $timezone);
        GetOptions(
            "today"      => \$today,
            "week"       => \$week,
            "days=i"     => \$days,
            "timezone=s" => \$timezone,
        );

        my $now = time;
        my $duration_days = 1;
        $duration_days = 7 if $week;
        $duration_days = $days if $days;
        
        my $start_of_period = strftime("%Y-%m-%dT00:00:00+09:00", localtime($now));
        my $end_of_period   = strftime("%Y-%m-%dT23:59:59+09:00", localtime($now + ($duration_days - 1) * 86400));
        
        my $data = $dooray->list_events($start_of_period, $end_of_period);
        print "Agenda ($start_of_period to $end_of_period):\n";
        my @events = sort { ($a->{startedAt} || '') cmp ($b->{startedAt} || '') } @{$data->{result}};
        foreach my $event (@events) {
            my $start = $event->{startedAt} || 'All Day';
            printf " [%-25s] %s\n", $start, $event->{subject};
        }
    } elsif ($sub eq 'events' || $sub eq '+insert' || $sub eq '+quickAdd') {
        my $action = ($sub eq '+insert') ? 'create' : (($sub eq '+quickAdd') ? 'create' : shift @ARGV);
        if ($action eq 'create' || $action eq 'insert' || $action eq 'quickAdd') {
            my ($subject, $summary, $start, $end, $location, $calendar_id, $params_meta, @attendees, $text, $busy);
            GetOptions(
                "subject=s"     => \$subject,
                "summary=s"     => \$summary,
                "start=s"       => \$start,
                "end=s"         => \$end,
                "location=s"    => \$location,
                "calendarId=s"  => \$calendar_id,
                "calendar-id=s" => \$calendar_id,
                "params=s"      => \$params_meta,
                "attendee=s"    => \@attendees,
                "text=s"        => \$text,
                "busy"          => \$busy,
                "public"        => \my $public,
            );
            $subject ||= $summary || $text || shift @ARGV;
            
            if ($params_meta) {
                my $context = join(' ', $params_meta, @ARGV);
                $context =~ s/\\(["'])/$1/g;
                if ($context =~ /summary\W+([^"',}\s]+)/i || $context =~ /subject\W+([^"',}\s]+)/i) {
                    $subject = $1;
                }
                if ($context =~ /startedAt\W+([^"',}\s]+|{[^}]+})\W+endedAt/i) {
                   # handle nested later if needed
                }
                if ($context =~ /dateTime\W+([^"',}\s]+)/i) {
                    $start = $1;
                }
            }
            
            die "Usage: delight calendar +insert --summary <subject>\n" unless $subject;
            
            
            $calendar_id ||= $config->get('default_calendar_id');
            if (!$calendar_id || $calendar_id eq 'primary') {
                $calendar_id = $dooray->get_default_calendar_id();
            }
            
    

            my $now = time;
            if ($start) {
                if (!$end) {
                    eval {
                        # Dooray format: 2026-03-22T20:00:00+09:00
                        my $s_clean = $start;
                        $s_clean =~ s/(\+\d{2}):(\d{2})$/$1$2/; # Remove colon for strptime %z
                        my $t = Time::Piece->strptime($s_clean, "%Y-%m-%dT%H:%M:%S%z");
                        my $t_end = $t + 3600;
                        $end = $t_end->strftime("%Y-%m-%dT%H:%M:%S");
                        my $tz = $t_end->strftime("%z");
                        $tz =~ s/(\d{2})(\d{2})$/$1:$2/; # Add colon back
                        $end .= $tz;
                    };
                    if ($@ || !$end) {
                        $end = $start; $end =~ s/T(\d{2})/sprintf("T%02d", ($1+1)%24)/e;
                    }
                }
            } else {
                $start = strftime("%Y-%m-%dT%H:%M:%S+09:00", localtime($now + 3600));
                $end   ||= strftime("%Y-%m-%dT%H:%M:%S+09:00", localtime($now + 7200));
            }
            
            my @to_members = ({ type => 'member', member => { organizationMemberId => $dooray->whoami()->{result}{id} } });
            for my $att (@attendees) {
                my $search_res = ($att =~ /@/) ? $dooray->search_members_by_email($att) : $dooray->search_members($att);
                my $members = $search_res->{result} || [];
                if (@$members) {
                    my $m = $members->[0];
                    push @to_members, { type => 'member', member => { organizationMemberId => $m->{id} } };
                    print "Attendee added: $m->{name}\n";
                } elsif ($att =~ /@/) {
                    push @to_members, { type => 'emailUser', emailUser => { emailAddress => $att } };
                    print "Attendee added (email): $att\n";
                } else {
                    warn "Warning: Member '$att' not found, skipped.\n";
                }
            }

            my $event_data = {
                users     => { to => \@to_members },
                subject   => $subject,
                body      => { mimeType => "text/plain", content => "Created via Delight CLI" },
                startedAt => $start,
                endedAt   => $end,
                location  => $location || "",
                personalSettings => {
                    busy  => $busy ? JSON::PP::true : JSON::PP::false,
                    class => $public ? "public" : "private",
                },
            };

            my $res = $dooray->create_event($calendar_id, $event_data);
            print "Event created successfully! ID: " . $res->{result}{id} . "\n";
        } elsif ($action eq 'list') {
            my ($calendar_id, $max_results, $q);
            GetOptions(
                "calendarId=s"  => \$calendar_id,
                "calendar-id=s" => \$calendar_id,
                "maxResults=i"  => \$max_results,
                "q=s"           => \$q,
            );
            $calendar_id ||= $config->get('default_calendar_id') || 'primary';
            if ($calendar_id eq 'primary') {
                $calendar_id = '*'; # Dooray wildcard
            }
            
    
            my $now = time;
            my $start = strftime("%Y-%m-%dT00:00:00+09:00", localtime($now - 7 * 86400)); # Last 7 days
            my $end   = strftime("%Y-%m-%dT23:59:59+09:00", localtime($now + 7 * 86400)); # Next 7 days
            
            my $data = $dooray->list_events($start, $end, q => $q, maxResults => $max_results);
            foreach my $event (@{$data->{result}}) {
                if ($calendar_id ne '*' && $event->{calendar}{id} ne $calendar_id) {
                    next;
                }
                printf "%-25s | %-25s | %-25s | %s\n", $event->{id}, $event->{calendar}{id} || "unknown", $event->{startedAt} || "All Day", $event->{subject};
            }
        } elsif ($action eq 'get' || $action eq 'delete' || $action eq 'update') {
            my ($calendar_id, $event_id, $summary, $start, $end, $location, $delete_type);
            GetOptions(
                "calendarId=s"  => \$calendar_id,
                "eventId=s"     => \$event_id,
                "summary=s"     => \$summary,
                "start=s"       => \$start,
                "end=s"         => \$end,
                "location=s"    => \$location,
                "deleteType=s"  => \$delete_type,
            );
            $event_id ||= shift @ARGV;
            die "Usage: delight calendar events $action --eventId <id>\n" unless $event_id;

            if (!$calendar_id || $calendar_id eq 'primary') {
                $calendar_id = $dooray->get_default_calendar_id();
            }

            if ($action eq 'get') {
                my $res = $dooray->get_event($calendar_id, $event_id);
                print "Event ID:    " . $res->{result}{id} . "\n";
                print "Subject:     " . $res->{result}{subject} . "\n";
                print "Started At:  " . ($res->{result}{startedAt} || "N/A") . "\n";
                print "Ended At:    " . ($res->{result}{endedAt} || "N/A") . "\n";
                print "Location:    " . ($res->{result}{location} || "") . "\n";
            } elsif ($action eq 'delete') {
                $dooray->delete_event($calendar_id, $event_id, deleteType => $delete_type);
                print "Event deleted successfully.\n";
            } elsif ($action eq 'update') {
                my $event = $dooray->get_event($calendar_id, $event_id)->{result};
                $event->{subject}   = $summary  if defined $summary;
                $event->{startedAt} = $start    if defined $start;
                $event->{endedAt}   = $end      if defined $end;
                $event->{location}  = $location if defined $location;
                $dooray->update_event($calendar_id, $event_id, $event);
                print "Event updated successfully.\n";
            }
        } elsif ($action eq 'invite') {
            my ($calendar_id, $event_id, $name, @attendees);
            GetOptions(
                "calendarId=s"  => \$calendar_id,
                "eventId=s"     => \$event_id,
                "name=s"        => \$name,
                "attendee=s"    => \@attendees,
            );
            $event_id ||= shift @ARGV;
            $name     ||= shift @ARGV unless @attendees;
            push @attendees, $name if $name;

            die "Usage: delight calendar invite --eventId <id> --attendee <name|email>\n" unless $event_id && @attendees;

            if (!$calendar_id || $calendar_id eq 'primary') {
                $calendar_id = $dooray->get_default_calendar_id();
            }

            # 1. Get current event to preserve data
            my $event = $dooray->get_event($calendar_id, $event_id)->{result};
            $event->{users} ||= { to => [] };

            # 2. Search and add each attendee
            for my $att (@attendees) {
                my $search_res = ($att =~ /@/) ? $dooray->search_members_by_email($att) : $dooray->search_members($att);
                my $members = $search_res->{result} || [];
                if (@$members) {
                    my $m = $members->[0];
                    push @{$event->{users}{to}}, {
                        type   => 'member',
                        member => { organizationMemberId => $m->{id} }
                    };
                    print "Attendee added: $m->{name}\n";
                } elsif ($att =~ /@/) {
                    push @{$event->{users}{to}}, {
                        type      => 'emailUser',
                        emailUser => { emailAddress => $att }
                    };
                    print "Attendee added (email): $att\n";
                } else {
                    warn "Warning: Member '$att' not found, skipped.\n";
                }
            }

            # 3. Update
            $dooray->update_event($calendar_id, $event_id, $event);
            print "Event updated successfully.\n";
        }
    } elsif ($sub eq 'freebusy') {
        my $action = shift @ARGV;
        if ($action eq 'query') {
            my $params_meta;
            GetOptions("params=s" => \$params_meta);
            # Note: Dooray free-busy query might need translation from GWS style
            # For now, just pass through if it's JSON
            if ($params_meta) {
                 my $json = JSON::PP->new->utf8->pretty;
                 my $res = $dooray->query_freebusy($json->decode($params_meta));
                 print "Free-Busy Query result:\n";
                 print $json->encode($res) . "\n";
            }
        }
    }
} elsif ($command eq 'drive') {
    my $sub = shift @ARGV;
    my ($json_meta, $params_meta, $upload_path, $name, $parent_id, $drive_id, $project_id, $wiki_id, $size);

    if ($sub eq 'files') {
        my $action = shift @ARGV;
        if ($action eq 'create') {
            GetOptions(
                "json=s"      => \$json_meta,
                "upload=s"    => \$upload_path,
                "name=s"      => \$name,
                "parent-id=s" => \$parent_id,
                "drive-id=s"  => \$drive_id,
                "project-id=s"=> \$project_id,
                "wiki-id=s"   => \$wiki_id,
            );
        } elsif ($action eq 'list') {
            GetOptions(
                "params=s"    => \$params_meta,
                "size=i"      => \$size,
                "drive-id=s"  => \$drive_id,
                "project-id=s"=> \$project_id,
                "wiki-id=s"   => \$wiki_id,
            );
            
            if ($params_meta) {
                my $context = join(' ', $params_meta, @ARGV);
                $context =~ s/\\(["'])/$1/g;
                if ($context =~ /pageSize\W+(\d+)/i) {
                    $size = $1;
                }
            }
            $size ||= 5;
        }
    } elsif ($sub eq '+upload') {
        $upload_path = shift @ARGV;
        GetOptions("name=s" => \$name);
    }
    
    # Common Drive Resolution
    if ($sub eq 'files' || $sub eq '+upload' || ($command eq 'download' && $sub eq 'drive')) {
        unless ($drive_id) {
            if ($project_id) {
                $drive_id = $dooray->get_drive_id_by_project_id($project_id);
            } elsif ($wiki_id) {
                $drive_id = $dooray->get_drive_id_by_wiki_id($wiki_id);
            } else {
                my $def_drive   = $config->get('default_drive_id');
                my $def_project = $config->get('default_project_id');
                my $def_wiki    = $config->get('default_wiki_id');
                
                if ($def_drive) {
                    $drive_id = $def_drive;
                } elsif ($def_project) {
                    $drive_id = $dooray->get_drive_id_by_project_id($def_project);
                } elsif ($def_wiki) {
                    $drive_id = $dooray->get_drive_id_by_wiki_id($def_wiki);
                }
            }
        }
        $drive_id ||= $dooray->get_private_drive_id();
    }
    
    if ($command eq 'drive') {
        if ($upload_path) {
            die "Error: File not found: $upload_path\n" unless -e $upload_path;
            
            if ($json_meta && !$name) {
                my $context = join(' ', $json_meta, @ARGV);
                $context =~ s/\\(["'])/$1/g;
                if ($context =~ /name\W+([^"',}\s]+)/i) {
                    $name = $1;
                }
            }
            $name ||= (File::Spec->splitpath($upload_path))[2];
            
            printf "Uploading $upload_path to Drive as '%s'...\n", $name;
            my $result = $dooray->upload_file($drive_id, $upload_path, $name, $parent_id);
            print "Uploaded successfully! File ID: " . $result->{result}{id} . "\n";
        } elsif ($size) {
            my $data = $dooray->list_files($drive_id, size => $size);
            printf "%-25s | %-30s | %s\n", "ID", "Name", "Created At";
            print "-" x 80 . "\n";
            foreach my $file (@{$data->{result}}) {
                printf "%-25s | %-30s | %s\n", $file->{id}, substr($file->{name}, 0, 30), $file->{createdAt};
            }
        } else {
             print "Usage: delight drive files create --upload <path> [options]\n";
             print "       delight drive files list --size <count> [options]\n";
             print "       delight drive +upload <path>\n";
        }
    }
} elsif ($command eq 'page' || $command eq 'wiki') {
    my $sub = shift @ARGV;
    if ($sub eq 'create') {
        my ($subject, $content, $wiki_id, $project_id, $parent_id);
        GetOptions(
            "subject=s"   => \$subject,
            "content=s"   => \$content,
            "wiki-id=s"   => \$wiki_id,
            "project-id=s"=> \$project_id,
            "parent-id=s" => \$parent_id,
        );
        $subject ||= shift @ARGV;
        die "Usage: delight page create --subject <title> [--content <text>] [--parent-id <id>]\n" unless $subject;

        $wiki_id = resolve_wiki_id($wiki_id, undef, $project_id);
        die "Error: wiki-id not found. Provide --wiki-id or configure default_wiki_id.\n" unless $wiki_id;

        unless ($parent_id) {
            my $wikis = $dooray->list_wikis()->{result} || [];
            for my $w (@$wikis) {
                if ($w->{id} eq $wiki_id) {
                    $parent_id = $w->{home}{pageId};
                    last;
                }
            }
        }

        my $data = {
            subject => $subject,
            body => {
                mimeType => "text/x-markdown",
                content  => $content || "",
            },
        };
        $data->{parentPageId} = $parent_id if $parent_id;

        my $res = $dooray->create_wiki_page($wiki_id, $data);
        print "Wiki page created successfully! ID: " . $res->{result}{id} . "\n";
    } elsif ($sub eq 'update') {
        my ($page_id, $subject, $content, $wiki_id, $project_id);
        GetOptions(
            "page-id=s"   => \$page_id,
            "subject=s"   => \$subject,
            "content=s"   => \$content,
            "wiki-id=s"   => \$wiki_id,
            "project-id=s"=> \$project_id,
        );
        $page_id ||= shift @ARGV;
        die "Usage: delight page update --page-id <id> [--subject <title>] [--content <text>]\n" unless $page_id;

        $wiki_id = resolve_wiki_id($wiki_id, $page_id, $project_id);
        die "Error: wiki-id not found. Provide --wiki-id or configure default_wiki_id.\n" unless $wiki_id;

        unless ($subject) {
            my $current = $dooray->get_wiki_page_detail($wiki_id, $page_id);
            $subject = $current->{result}{subject};
        }

        my $data = { subject => $subject };
        if (defined $content) {
            $data->{body} = {
                mimeType => "text/x-markdown",
                content  => $content,
            };
        }

        my $res = $dooray->update_wiki_page($wiki_id, $page_id, $data);
        print "Wiki page updated successfully!\n";
    } elsif ($sub eq 'upload') {
        my ($page_id, $wiki_id, $project_id, $file);
        GetOptions(
            "page-id=s"    => \$page_id,
            "wiki-id=s"    => \$wiki_id,
            "project-id=s" => \$project_id,
            "file=s"       => \$file,
        );
        $page_id ||= shift @ARGV;
        die "Usage: delight page upload --page-id <id> [--file <path>]\n" unless $page_id;

        $wiki_id = resolve_wiki_id($wiki_id, $page_id, $project_id);
        die "Error: wiki-id not found. Provide --wiki-id or configure default_wiki_id.\n" unless $wiki_id;

        unless ($file) {
            my $base_dir = base_dir();
            $file = File::Spec->catfile($base_dir, "wiki_$wiki_id", "$page_id.md");
        }
        die "Error: File not found: $file\n" unless -f $file;

        open my $fh, '<:encoding(UTF-8)', $file or die "Could not open $file: $!\n";
        my $content = do { local $/; <$fh> };
        close $fh;

        my $current = $dooray->get_wiki_page_detail($wiki_id, $page_id);
        my $subject = $current->{result}{subject};

        $dooray->update_wiki_page($wiki_id, $page_id, {
            subject => $subject,
            body    => { mimeType => "text/x-markdown", content => $content },
        });
        print "Wiki page uploaded from $file\n";

        # If file is outside download dir, download to canonical location
        my $base_dir = base_dir();
        my $wiki_dir = File::Spec->catdir($base_dir, "wiki_$wiki_id");
        my $canonical = File::Spec->catfile($wiki_dir, "$page_id.md");
        if (File::Spec->rel2abs($file) ne File::Spec->rel2abs($canonical)) {
            make_path($wiki_dir) unless -d $wiki_dir;
            open my $out, '>:encoding(UTF-8)', $canonical or die "Could not open $canonical: $!\n";
            print $out $content;
            close $out;
            print "Downloaded to $canonical\n";
            print "Next time, edit and upload from: $canonical\n";
        }
    } elsif ($sub eq 'download') {
        my ($page_id, $wiki_id, $project_id);
        GetOptions(
            "page-id=s"    => \$page_id,
            "wiki-id=s"    => \$wiki_id,
            "project-id=s" => \$project_id,
        );
        $page_id ||= shift @ARGV;
        die "Usage: delight page download --page-id <id>\n" unless $page_id;

        $wiki_id = resolve_wiki_id($wiki_id, $page_id, $project_id);
        die "Error: wiki-id not found. Provide --wiki-id or configure default_wiki_id.\n" unless $wiki_id;

        my $detail = $dooray->get_wiki_page_detail($wiki_id, $page_id);
        my $data = $detail->{result};
        my $format = ($data->{body}{mimeType} || '') eq 'text/html' ? 'html' : 'md';
        my $content = $data->{body}{content} || '';

        my $base_dir = base_dir();
        my $wiki_dir = File::Spec->catdir($base_dir, "wiki_$wiki_id");
        make_path($wiki_dir) unless -d $wiki_dir;

        my $fpath = File::Spec->catfile($wiki_dir, "${page_id}.$format");
        open my $fh, '>:utf8', $fpath or die "Cannot write $fpath: $!\n";
        print $fh $content;
        close $fh;
        print "Saved to $fpath\n";
    } elsif ($sub eq 'delete') {
        my ($page_id, $wiki_id, $project_id);
        GetOptions(
            "page-id=s"    => \$page_id,
            "wiki-id=s"    => \$wiki_id,
            "project-id=s" => \$project_id,
        );
        $page_id ||= shift @ARGV;
        die "Usage: delight page delete --page-id <id>\n" unless $page_id;

        $wiki_id = resolve_wiki_id($wiki_id, $page_id, $project_id);
        die "Error: wiki-id not found. Provide --wiki-id or configure default_wiki_id.\n" unless $wiki_id;

        my $current = $dooray->get_wiki_page_detail($wiki_id, $page_id);
        my $result = $current->{result};
        my $subject = $result->{subject};
        $subject = "#TBD $subject" unless $subject =~ /^#TBD /;
        $dooray->update_wiki_page($wiki_id, $page_id, {
            subject => $subject,
            body    => $result->{body},
        });
        print "Wiki page marked as deleted: $subject\n";

        # Remove local copy if exists
        my $base_dir = base_dir();
        my $wiki_dir = File::Spec->catdir($base_dir, "wiki_$wiki_id");
        for my $ext ('md', 'html') {
            my $fpath = File::Spec->catfile($wiki_dir, "$page_id.$ext");
            if (-f $fpath) {
                unlink $fpath;
                print "Removed local copy: $fpath\n";
            }
        }
    } elsif ($sub eq 'undelete') {
        my ($page_id, $wiki_id, $project_id);
        GetOptions(
            "page-id=s"    => \$page_id,
            "wiki-id=s"    => \$wiki_id,
            "project-id=s" => \$project_id,
        );
        $page_id ||= shift @ARGV;
        die "Usage: delight page undelete --page-id <id>\n" unless $page_id;

        $wiki_id = resolve_wiki_id($wiki_id, $page_id, $project_id);
        die "Error: wiki-id not found. Provide --wiki-id or configure default_wiki_id.\n" unless $wiki_id;

        my $current = $dooray->get_wiki_page_detail($wiki_id, $page_id);
        my $result = $current->{result};
        my $subject = $result->{subject};
        $subject =~ s/^#TBD\s*//;
        $dooray->update_wiki_page($wiki_id, $page_id, {
            subject => $subject,
            body    => $result->{body},
        });
        print "Wiki page undeleted: $subject\n";

        # Download if local copy is not available
        my $base_dir = base_dir();
        my $wiki_dir = File::Spec->catdir($base_dir, "wiki_$wiki_id");
        my $fpath = File::Spec->catfile($wiki_dir, "$page_id.md");
        unless (-f $fpath) {
            make_path($wiki_dir) unless -d $wiki_dir;
            my $body_content = $result->{body}{content} || '';
            open my $fh, '>:encoding(UTF-8)', $fpath or die "Could not open $fpath: $!\n";
            print $fh "# $subject\n\n$body_content\n";
            close $fh;
            print "Downloaded to $fpath\n";
        }
    } elsif ($sub eq 'search') {
        my ($wiki_id, $project_id, $include_tasks);
        GetOptions(
            "wiki-id=s"     => \$wiki_id,
            "project-id=s"  => \$project_id,
            "include-tasks" => \$include_tasks,
        );
        my $query = shift @ARGV;
        die "Usage: delight wiki search <query> [--wiki-id <id>] [--include-tasks] [--project-id <id>]\n" unless $query;

        $wiki_id = resolve_wiki_id($wiki_id, undef, $project_id);
        die "Error: wiki-id not found.\n" unless $wiki_id;

        my ($home_id, $proj_for_links) = _wiki_meta($wiki_id);
        die "Error: wiki home not found.\n" unless $home_id;

        my $q_re = qr/\Q$query\E/i;
        my @pages = _load_wiki_pages_with_body($wiki_id, $home_id);
        my $page_hits = 0;
        print "=== Wiki pages ===\n";
        for my $p (@pages) {
            my $subject = $p->{subject} // '';
            my $body    = $p->{body} // '';
            my @snippets;
            for my $line (split /\n/, $body) {
                if ($line =~ $q_re) {
                    push @snippets, $line if @snippets < 3;
                }
            }
            next unless ($subject =~ $q_re) || @snippets;
            $page_hits++;
            print "  $p->{id} | $subject\n";
            print "    > $_\n" for @snippets;
        }
        print "  (no matches)\n" unless $page_hits;

        if ($include_tasks) {
            $project_id ||= $proj_for_links || $config->get('default_project_id');
            die "Error: project-id not found for tasks search.\n" unless $project_id;
            print "\n=== Tasks (subject only) ===\n";
            my $task_hits = 0;
            my $page = 0;
            while (1) {
                my $r = $dooray->list_posts_paginated($project_id, $page, 100);
                my $items = $r->{result} || [];
                last unless @$items;
                for my $t (@$items) {
                    next unless ($t->{subject} // '') =~ $q_re;
                    print "  $t->{id} | $t->{subject}\n";
                    $task_hits++;
                }
                last if scalar(@$items) < 100;
                $page++;
            }
            print "  (no matches)\n" unless $task_hits;
        }
    } elsif ($sub eq 'index') {
        my ($wiki_id, $project_id, $save);
        GetOptions(
            "wiki-id=s"    => \$wiki_id,
            "project-id=s" => \$project_id,
            "save"         => \$save,
        );
        $wiki_id = resolve_wiki_id($wiki_id, undef, $project_id);
        die "Error: wiki-id not found.\n" unless $wiki_id;

        my ($home_id, $proj_for_links, $wiki_name) = _wiki_meta($wiki_id);
        die "Error: wiki home not found.\n" unless $home_id;

        my @pages = _walk_wiki_pages($wiki_id, $home_id);
        my $out = "# $wiki_name — Wiki Index\n\n";
        for my $p (@pages) {
            next if ($p->{subject} // '') =~ /^#TBD /;
            my $indent = '  ' x $p->{_depth};
            my $subject = $p->{subject} // '';
            $out .= "$indent- [$subject](dooray://$proj_for_links/pages/$p->{id})\n";
        }

        if ($save) {
            my $index_page;
            for my $p (@pages) {
                if (($p->{subject} // '') =~ /^Index$/i) { $index_page = $p; last; }
            }
            if ($index_page) {
                $dooray->update_wiki_page($wiki_id, $index_page->{id}, {
                    subject => $index_page->{subject},
                    body    => { mimeType => 'text/x-markdown', content => $out },
                });
                print "Index page updated: $index_page->{id}\n";
            } else {
                my $res = $dooray->create_wiki_page($wiki_id, {
                    subject      => "Index",
                    parentPageId => $home_id,
                    body         => { mimeType => 'text/x-markdown', content => $out },
                });
                print "Index page created: " . $res->{result}{id} . "\n";
            }
        } else {
            print $out;
        }
    } elsif ($sub eq 'backlinks') {
        my ($wiki_id, $project_id, $apply);
        GetOptions(
            "wiki-id=s"    => \$wiki_id,
            "project-id=s" => \$project_id,
            "apply"        => \$apply,
        );
        $wiki_id = resolve_wiki_id($wiki_id, undef, $project_id);
        die "Error: wiki-id not found.\n" unless $wiki_id;

        my ($home_id, $proj_for_links) = _wiki_meta($wiki_id);
        die "Error: wiki home not found.\n" unless $home_id;

        my @pages = _load_wiki_pages_with_body($wiki_id, $home_id);
        my %page_by_id = map { $_->{id} => $_ } @pages;

        my $missing = 0;
        for my $src (@pages) {
            my $body = $src->{body} // '';
            my %seen;
            while ($body =~ m{dooray://[^/\s]+/(tasks|pages)/(\d+)}g) {
                my ($kind, $tgt_id) = ($1, $2);
                next if $tgt_id eq $src->{id};
                next if $seen{"$kind:$tgt_id"}++;
                if ($kind eq 'pages') {
                    my $tgt = $page_by_id{$tgt_id} or next;
                    next if ($tgt->{body} // '') =~ m{dooray://[^/\s]+/pages/$src->{id}\b};
                    print "Missing back-link: page:$tgt_id -> page:$src->{id}\n";
                    $missing++;
                    if ($apply) {
                        my $ref_line = "- [$src->{subject}](dooray://$proj_for_links/pages/$src->{id})";
                        my $new_body = _add_reference($tgt->{body}, $ref_line, undef);
                        $dooray->update_wiki_page($wiki_id, $tgt_id, {
                            subject => $tgt->{subject},
                            body    => { mimeType => 'text/x-markdown', content => $new_body },
                        });
                        $tgt->{body} = $new_body;
                        print "  applied.\n";
                    }
                } else {
                    my $detail = eval { $dooray->get_post_detail($proj_for_links, $tgt_id)->{result} };
                    next unless $detail;
                    my $tgt_body = $detail->{body}{content} // '';
                    next if $tgt_body =~ m{dooray://[^/\s]+/pages/$src->{id}\b};
                    print "Missing back-link: task:$tgt_id -> page:$src->{id}\n";
                    $missing++;
                    if ($apply) {
                        my $ref_line = "- [$src->{subject}](dooray://$proj_for_links/pages/$src->{id})";
                        my $new_body = _add_reference($tgt_body, $ref_line, undef);
                        $dooray->update_post($proj_for_links, $tgt_id, {
                            subject => $detail->{subject},
                            body    => { mimeType => 'text/x-markdown', content => $new_body },
                        });
                        print "  applied.\n";
                    }
                }
            }
        }
        print "\nMissing back-links: $missing\n";
        print "Run with --apply to add them.\n" if $missing && !$apply;
    } elsif ($sub eq 'graph') {
        my ($wiki_id, $project_id, $format);
        GetOptions(
            "wiki-id=s"    => \$wiki_id,
            "project-id=s" => \$project_id,
            "format=s"     => \$format,
        );
        $format ||= 'text';
        $wiki_id = resolve_wiki_id($wiki_id, undef, $project_id);
        die "Error: wiki-id not found.\n" unless $wiki_id;

        my ($home_id) = _wiki_meta($wiki_id);
        die "Error: wiki home not found.\n" unless $home_id;

        my @pages = _load_wiki_pages_with_body($wiki_id, $home_id);
        my %nodes = map { $_->{id} => $_->{subject} } @pages;
        my @edges;
        my %in_count;
        for my $p (@pages) {
            my %seen;
            while ($p->{body} =~ m{dooray://[^/\s]+/(tasks|pages)/(\d+)}g) {
                my ($kind, $tgt) = ($1, $2);
                next if $tgt eq $p->{id};
                next if $seen{"$kind:$tgt"}++;
                push @edges, [$p->{id}, $tgt, $kind];
                $in_count{$tgt}++ if $kind eq 'pages';
            }
        }

        if ($format eq 'dot') {
            print "digraph wiki {\n";
            print "  rankdir=LR;\n";
            for my $id (sort keys %nodes) {
                my $label = $nodes{$id} // '';
                $label =~ s/"/\\"/g;
                print qq{  "$id" [label="$label"];\n};
            }
            for my $e (@edges) {
                print qq{  "$e->[0]" -> "$e->[1]" [label="$e->[2]"];\n};
            }
            print "}\n";
        } elsif ($format eq 'json') {
            my $data = {
                nodes => [ map { { id => $_, subject => $nodes{$_} } } sort keys %nodes ],
                edges => [ map { { from => $_->[0], to => $_->[1], kind => $_->[2] } } @edges ],
            };
            print JSON::PP->new->pretty->canonical->encode($data);
        } else {
            print "Pages: " . scalar(keys %nodes) . "\n";
            print "Edges: " . scalar(@edges) . "\n\n";
            my @orphans = grep { !$in_count{$_} } sort keys %nodes;
            print "Orphans (no inbound page links): " . scalar(@orphans) . "\n";
            for my $id (@orphans) {
                print "  $id | " . ($nodes{$id} // '') . "\n";
            }
            print "\nHubs (most inbound):\n";
            my @sorted = sort { ($in_count{$b}||0) <=> ($in_count{$a}||0) } keys %in_count;
            my $top = @sorted > 5 ? 4 : $#sorted;
            for my $id (@sorted[0..$top]) {
                printf "  %d | %s | %s\n", $in_count{$id}, $id, $nodes{$id} // '?';
            }
        }
    } elsif ($sub eq 'compile') {
        my ($wiki_id, $project_id, $save, $include_tasks);
        GetOptions(
            "wiki-id=s"     => \$wiki_id,
            "project-id=s"  => \$project_id,
            "save"          => \$save,
            "include-tasks" => \$include_tasks,
        );
        my $topic = shift @ARGV;
        die "Usage: delight wiki compile <topic> [--save] [--include-tasks]\n" unless $topic;

        $wiki_id = resolve_wiki_id($wiki_id, undef, $project_id);
        die "Error: wiki-id not found.\n" unless $wiki_id;

        my ($home_id, $proj_for_links) = _wiki_meta($wiki_id);
        die "Error: wiki home not found.\n" unless $home_id;
        $project_id ||= $proj_for_links;

        my $q_re = qr/\Q$topic\E/i;
        my @pages = _load_wiki_pages_with_body($wiki_id, $home_id);
        my @page_hits;
        for my $p (@pages) {
            next if ($p->{subject} // '') =~ /^#TBD /;
            next unless ($p->{subject} =~ $q_re) || ($p->{body} =~ $q_re);
            push @page_hits, $p;
        }

        my @task_hits;
        if ($include_tasks && $project_id) {
            my $page = 0;
            while (1) {
                my $r = $dooray->list_posts_paginated($project_id, $page, 100);
                my $items = $r->{result} || [];
                last unless @$items;
                for my $t (@$items) {
                    next if ($t->{subject} // '') =~ /^#TBD /;
                    next unless ($t->{subject} // '') =~ $q_re;
                    my $det = $dooray->get_post_detail($project_id, $t->{id})->{result};
                    push @task_hits, {
                        id => $t->{id}, subject => $det->{subject}, body => $det->{body}{content} // '',
                    };
                }
                last if scalar(@$items) < 100;
                $page++;
            }
        }

        warn sprintf("Found %d page(s), %d task(s) for topic '%s'\n",
            scalar @page_hits, scalar @task_hits, $topic);
        die "No matches.\n" unless @page_hits || @task_hits;

        my $bundle = '';
        for my $p (@page_hits) {
            $bundle .= "\n--- PAGE id=$p->{id}: $p->{subject} ---\n$p->{body}\n";
        }
        for my $t (@task_hits) {
            $bundle .= "\n--- TASK id=$t->{id}: $t->{subject} ---\n$t->{body}\n";
        }

        my $prompt = <<"PROMPT";
당신은 사내 위키 편집자입니다. 아래 자료를 종합해서 "$topic"에 관한 정식 위키 엔트리를 한국어 마크다운으로 작성하세요.

다음 구조를 따르세요:
# $topic

## 개요
2-3 문장으로 무엇인지 요약.

## 동작
명령 사용법, 옵션, 동작 흐름. 코드 블록과 예시 포함.

## 최근 변경
관련 태스크/페이지에서 추출한 변경 이력.

## 관련 링크
관련 태스크/페이지의 링크 목록.

규칙:
- 자료에 없는 내용은 만들지 마세요. 사실 위주로 간결하게.
- 출력은 마크다운 본문만. 설명/추가 문구 없이.
- 다른 페이지/태스크를 참조할 때는 반드시 다음 형식의 링크를 사용하세요:
    - 페이지: [제목](dooray://$project_id/pages/<pageId>)
    - 태스크: [제목](dooray://$project_id/tasks/<taskId>)
  자료에 등장하는 ID를 그대로 사용하세요. 형식을 줄이거나 변형하지 마세요.

자료:
$bundle
PROMPT

        my $output = _llm_complete($prompt);

        if ($save) {
            my $existing;
            for my $p (@pages) {
                if (($p->{subject} // '') eq $topic) { $existing = $p; last; }
            }
            if ($existing) {
                $dooray->update_wiki_page($wiki_id, $existing->{id}, {
                    subject => $existing->{subject},
                    body    => { mimeType => 'text/x-markdown', content => $output },
                });
                print "Wiki page updated: $existing->{id} ($topic)\n";
            } else {
                my $res = $dooray->create_wiki_page($wiki_id, {
                    subject      => $topic,
                    parentPageId => $home_id,
                    body         => { mimeType => 'text/x-markdown', content => $output },
                });
                print "Wiki page created: " . $res->{result}{id} . " ($topic)\n";
            }
        } else {
            print $output;
            print "\n" unless $output =~ /\n$/;
        }
    }
} elsif ($command eq 'task' || $command eq 'post') {
    my $sub = shift @ARGV;
    if ($sub eq 'create') {
        my ($subject, $content, $project_id);
        GetOptions(
            "subject=s"    => \$subject,
            "content=s"    => \$content,
            "project-id=s" => \$project_id,
        );
        $subject ||= shift @ARGV;
        die "Usage: delight task create --subject <title> [--content <text>] [--project-id <id>]\n" unless $subject;
        $project_id ||= $config->get('default_project_id');
        die "Error: project-id required. Provide --project-id or configure default_project_id.\n" unless $project_id;

        my $my_id = $dooray->whoami()->{result}{id};
        my $data = {
            subject => $subject,
            body    => { mimeType => "text/x-markdown", content => $content || "" },
            users   => { to => [{ type => "member", member => { organizationMemberId => $my_id } }] },
        };
        my $res = $dooray->create_post($project_id, $data);
        print "Task created successfully! ID: " . $res->{result}{id} . "\n";
    } elsif ($sub eq 'list') {
        my ($project_id, $size, @fields);
        GetOptions(
            "project-id=s" => \$project_id,
            "size=i"       => \$size,
            "fields=s"     => \@fields,
        );
        @fields = split(/,/, join(',', @fields)) if @fields;
        @fields = ('title', 'status') unless @fields;
        $project_id ||= shift @ARGV || $config->get('default_project_id');
        die "Usage: delight task list [--project-id <id>] [--size <n>] [--fields title,status,...]\n" unless $project_id;
        my $data = $dooray->list_posts_paginated($project_id, 0, $size || 100);
        foreach my $post (@{$data->{result}}) {
            print _format_task($post, \@fields) . "\n";
        }
        print "Total: $data->{totalCount}\n";
    } elsif ($sub eq 'count') {
        my ($project_id, $phase, @fields);
        GetOptions(
            "project-id=s" => \$project_id,
            "phase=s"      => \$phase,
            "fields=s"     => \@fields,
        );
        @fields = split(/,/, join(',', @fields)) if @fields;
        @fields = ('title', 'status') unless @fields;
        $project_id ||= shift @ARGV || $config->get('default_project_id');
        die "Usage: delight task count [--project-id <id>] [--phase <name>] [--fields title,status,...]\n" unless $project_id;

        my $path = "/project/v1/projects/$project_id/posts?page=0&size=1";
        if ($phase) {
            my $milestones = $dooray->list_milestones($project_id)->{result} || [];
            my $milestone_id;
            for my $m (@$milestones) {
                if ($m->{name} eq $phase) {
                    $milestone_id = $m->{id};
                    last;
                }
            }
            die "Error: Phase '$phase' not found.\n" unless $milestone_id;
            $path .= "&milestoneIds=$milestone_id";
        }
        my $data = $dooray->request('GET', $path);
        my $label = $phase ? "Total tasks in phase '$phase'" : "Total tasks";
        print "$label: $data->{totalCount}\n";

        if ($phase) {
            my $workflows = $dooray->list_workflows($project_id)->{result} || [];
            for my $w (@$workflows) {
                (my $list_path = $path) =~ s/size=1/size=100/;
                my $wdata = $dooray->request('GET', "$list_path&workflowIds=$w->{id}");
                my $count = $wdata->{totalCount} || 0;
                printf "  %-10s: %s\n", $w->{name}, $count;
                for my $post (@{$wdata->{result} || []}) {
                    print "    " . _format_task($post, \@fields) . "\n";
                }
            }
        }
    } elsif ($sub eq 'comment') {
        my ($task_id, $project_id, $content);
        GetOptions(
            "task-id=s"    => \$task_id,
            "post-id=s"    => \$task_id,
            "project-id=s" => \$project_id,
            "content=s"    => \$content,
        );
        $task_id ||= shift @ARGV;
        $content ||= join(' ', @ARGV);
        die "Usage: delight task comment --task-id <id> --content <text>\n" unless $task_id && $content;
        $project_id = resolve_project_id($project_id, $task_id);
        die "Error: project-id not found.\n" unless $project_id;

        $dooray->request('POST', "/project/v1/projects/$project_id/posts/$task_id/logs", {
            body => { mimeType => "text/x-markdown", content => $content }
        });
        print "Comment added.\n";
    } elsif ($sub eq 'tag') {
        my ($task_id, $project_id, @tags);
        GetOptions(
            "task-id=s"    => \$task_id,
            "post-id=s"    => \$task_id,
            "project-id=s" => \$project_id,
            "tag=s"        => \@tags,
        );
        $task_id ||= shift @ARGV;
        push @tags, @ARGV if @ARGV;
        die "Usage: delight task tag --task-id <id> --tag <name> [--tag <name>]\n" unless $task_id && @tags;
        $project_id = resolve_project_id($project_id, $task_id);
        die "Error: project-id not found.\n" unless $project_id;

        my $all_tags = $dooray->list_tags($project_id)->{result} || [];
        my %tag_map = map { $_->{name} => $_->{id} } @$all_tags;

        my @tag_ids;
        for my $t (@tags) {
            if ($tag_map{$t}) {
                push @tag_ids, $tag_map{$t};
                print "Tag: $t\n";
            } else {
                warn "Warning: Tag '$t' not found, skipped. Use 'delight project settings' to see available tags.\n";
            }
        }
        die "Error: No valid tags found.\n" unless @tag_ids;

        my $tag_prefix = { toTag => [ map { { id => $_ } } @tag_ids ] };
        $dooray->update_post($project_id, $task_id, { tagIdList => \@tag_ids });
        print "Task tagged successfully.\n";
    } elsif ($sub eq 'duedate') {
        my ($task_id, $project_id, $date, $today, $tomorrow);
        GetOptions(
            "task-id=s"    => \$task_id,
            "post-id=s"    => \$task_id,
            "project-id=s" => \$project_id,
            "date=s"       => \$date,
            "today"        => \$today,
            "tomorrow"     => \$tomorrow,
        );
        $task_id ||= shift @ARGV;
        $date    ||= shift @ARGV unless $today || $tomorrow;
        if ($today) {
            $date = strftime("%Y-%m-%dT23:59:59+09:00", localtime(time));
        } elsif ($tomorrow) {
            $date = strftime("%Y-%m-%dT23:59:59+09:00", localtime(time + 86400));
        }
        die "Usage: delight task duedate --task-id <id> --date <date> | --today | --tomorrow\n" unless $task_id && $date;
        $project_id = resolve_project_id($project_id, $task_id);
        die "Error: project-id not found.\n" unless $project_id;

        # Support bare date like 2026-04-16
        if ($date =~ /^\d{4}-\d{2}-\d{2}$/) {
            $date .= "T23:59:59+09:00";
        }

        $dooray->update_post($project_id, $task_id, { dueDate => $date });
        print "Task due date set to: $date\n";
    } elsif ($sub eq 'phase') {
        my ($task_id, $project_id, $phase);
        GetOptions(
            "task-id=s"    => \$task_id,
            "post-id=s"    => \$task_id,
            "project-id=s" => \$project_id,
            "phase=s"      => \$phase,
        );
        $task_id ||= shift @ARGV;
        $phase   ||= shift @ARGV;
        die "Usage: delight task phase --task-id <id> --phase <name>\n" unless $task_id && $phase;
        $project_id = resolve_project_id($project_id, $task_id);
        die "Error: project-id not found.\n" unless $project_id;

        my $milestones = $dooray->list_milestones($project_id);
        my $milestone_id;
        for my $m (@{$milestones->{result} || []}) {
            if ($m->{name} eq $phase) {
                $milestone_id = $m->{id};
                last;
            }
        }
        die "Error: Phase '$phase' not found. Use 'delight project settings' to see available phases.\n" unless $milestone_id;
        $dooray->update_post($project_id, $task_id, { milestoneId => $milestone_id });
        print "Task phase changed to: $phase\n";
    } elsif ($sub eq 'status') {
        my ($task_id, $project_id, $status, $done);
        GetOptions(
            "task-id=s"    => \$task_id,
            "post-id=s"    => \$task_id,
            "project-id=s" => \$project_id,
            "status=s"     => \$status,
            "done"         => \$done,
        );
        $task_id ||= shift @ARGV;
        $status  ||= shift @ARGV unless $done;
        die "Usage: delight task status --task-id <id> --status <name> | --done\n" unless $task_id && ($status || $done);
        $project_id = resolve_project_id($project_id, $task_id);
        die "Error: project-id not found.\n" unless $project_id;

        if ($done) {
            $dooray->set_post_done($project_id, $task_id);
            print "Task marked as done.\n";
        } else {
            my $workflows = $dooray->list_workflows($project_id);
            my $workflow_id;
            for my $w (@{$workflows->{result} || []}) {
                if ($w->{name} eq $status) {
                    $workflow_id = $w->{id};
                    last;
                }
            }
            die "Error: Status '$status' not found. Use 'delight project settings' to see available statuses.\n" unless $workflow_id;
            $dooray->set_post_workflow($project_id, $task_id, $workflow_id);
            print "Task status changed to: $status\n";
        }
    } elsif ($sub eq 'assign') {
        my ($task_id, $project_id, @assignees);
        GetOptions(
            "task-id=s"    => \$task_id,
            "post-id=s"    => \$task_id,
            "project-id=s" => \$project_id,
            "assignee=s"   => \@assignees,
        );
        $task_id ||= shift @ARGV;
        die "Usage: delight task assign --task-id <id> [--assignee <name|email>]\n" unless $task_id;
        $project_id = resolve_project_id($project_id, $task_id);
        die "Error: project-id not found.\n" unless $project_id;

        my @to_members;
        if (@assignees) {
            for my $att (@assignees) {
                my $search_res = ($att =~ /@/) ? $dooray->search_members_by_email($att) : $dooray->search_members($att);
                my $members = $search_res->{result} || [];
                if (@$members) {
                    my $m = $members->[0];
                    push @to_members, { type => 'member', member => { organizationMemberId => $m->{id} } };
                    print "Assignee: $m->{name}\n";
                } else {
                    warn "Warning: Member '$att' not found, skipped.\n";
                }
            }
        } else {
            my $my_id = $dooray->whoami()->{result}{id};
            push @to_members, { type => 'member', member => { organizationMemberId => $my_id } };
            print "Assignee: me\n";
        }

        $dooray->update_post($project_id, $task_id, {
            users => { to => \@to_members },
        });
        print "Task assigned successfully.\n";
    } elsif ($sub eq 'delete') {
        my ($post_id, $project_id);
        GetOptions(
            "task-id=s"    => \$post_id,
            "post-id=s"    => \$post_id,
            "project-id=s" => \$project_id,
        );
        $post_id ||= shift @ARGV;
        die "Usage: delight task delete --task-id <id> [--project-id <id>]\n" unless $post_id;
        $project_id = resolve_project_id($project_id, $post_id);
        die "Error: project-id not found.\n" unless $project_id;

        my $current = $dooray->get_post_detail($project_id, $post_id);
        my $subject = $current->{result}{subject};
        $subject = "#TBD $subject" unless $subject =~ /^#TBD /;
        $dooray->update_post($project_id, $post_id, { subject => $subject });
        print "Task marked as deleted: $subject\n";

        # Remove local copy if exists
        my $base_dir = base_dir();
        my $task_dir = File::Spec->catdir($base_dir, "project_$project_id");
        for my $ext ('md', 'html') {
            my $fpath = File::Spec->catfile($task_dir, "$post_id.$ext");
            if (-f $fpath) {
                unlink $fpath;
                print "Removed local copy: $fpath\n";
            }
        }
    } elsif ($sub eq 'undelete') {
        my ($post_id, $project_id);
        GetOptions(
            "task-id=s"    => \$post_id,
            "post-id=s"    => \$post_id,
            "project-id=s" => \$project_id,
        );
        $post_id ||= shift @ARGV;
        die "Usage: delight task undelete --task-id <id> [--project-id <id>]\n" unless $post_id;
        $project_id = resolve_project_id($project_id, $post_id);
        die "Error: project-id not found.\n" unless $project_id;

        my $current = $dooray->get_post_detail($project_id, $post_id);
        my $subject = $current->{result}{subject};
        $subject =~ s/^#TBD\s*//;
        $dooray->update_post($project_id, $post_id, { subject => $subject });
        print "Task undeleted: $subject\n";

        # Download if local copy is not available
        my $base_dir = base_dir();
        my $task_dir = File::Spec->catdir($base_dir, "project_$project_id");
        my $fpath = File::Spec->catfile($task_dir, "$post_id.md");
        unless (-f $fpath) {
            make_path($task_dir) unless -d $task_dir;
            my $body_content = $current->{result}{body}{content} || '';
            open my $fh, '>:encoding(UTF-8)', $fpath or die "Could not open $fpath: $!\n";
            print $fh $body_content;
            close $fh;
            print "Downloaded to $fpath\n";
        }
    } elsif ($sub eq 'download') {
        my ($task_id, $project_id);
        GetOptions(
            "task-id=s"    => \$task_id,
            "post-id=s"    => \$task_id,
            "project-id=s" => \$project_id,
        );
        $task_id ||= shift @ARGV;
        die "Usage: delight task download --task-id <id> [--project-id <id>]\n" unless $task_id;
        $project_id = resolve_project_id($project_id, $task_id);
        die "Error: project-id not found.\n" unless $project_id;

        my $detail = $dooray->get_post_detail($project_id, $task_id);
        my $data = $detail->{result};
        my $format = ($data->{body}{mimeType} || '') eq 'text/html' ? 'html' : 'md';
        my $content = $data->{body}{content} || '';

        my $base_dir = base_dir();
        my $task_dir = File::Spec->catdir($base_dir, "project_$project_id");
        make_path($task_dir) unless -d $task_dir;

        my $fpath = File::Spec->catfile($task_dir, "${task_id}.$format");
        open my $fh, '>:utf8', $fpath or die "Cannot write $fpath: $!\n";
        print $fh $content;
        close $fh;
        print "Saved to $fpath\n";
    } elsif ($sub eq 'upload') {
        my ($task_id, $project_id, $file);
        GetOptions(
            "task-id=s"    => \$task_id,
            "post-id=s"    => \$task_id,
            "project-id=s" => \$project_id,
            "file=s"       => \$file,
        );
        $task_id ||= shift @ARGV;
        die "Usage: delight task upload --task-id <id> [--file <path>] [--project-id <id>]\n" unless $task_id;
        $project_id = resolve_project_id($project_id, $task_id);
        die "Error: project-id not found.\n" unless $project_id;

        unless ($file) {
            my $base_dir = base_dir();
            $file = File::Spec->catfile($base_dir, "project_$project_id", "$task_id.md");
        }
        die "Error: File not found: $file\n" unless -f $file;

        open my $fh, '<:encoding(UTF-8)', $file or die "Could not open $file: $!\n";
        my $content = do { local $/; <$fh> };
        close $fh;

        my $current = $dooray->get_post_detail($project_id, $task_id);
        my $subject = $current->{result}{subject};

        $dooray->update_post($project_id, $task_id, {
            subject => $subject,
            body    => { mimeType => "text/x-markdown", content => $content },
        });
        print "Task uploaded from $file\n";

        # If file is outside download dir, copy to canonical location
        my $base_dir = base_dir();
        my $task_dir = File::Spec->catdir($base_dir, "project_$project_id");
        my $canonical = File::Spec->catfile($task_dir, "$task_id.md");
        if (File::Spec->rel2abs($file) ne File::Spec->rel2abs($canonical)) {
            make_path($task_dir) unless -d $task_dir;
            open my $out, '>:encoding(UTF-8)', $canonical or die "Could not open $canonical: $!\n";
            print $out $content;
            close $out;
            print "Downloaded to $canonical\n";
            print "Next time, edit and upload from: $canonical\n";
        }
    }
} elsif ($command eq 'download') {
    my $sub = shift @ARGV;
    my ($reset_cache, $with_attachments, $project_id, $wiki_id, $drive_id, $delay, $page_id);
    $delay = 20; # Ensure default is 20s as requested
    GetOptions(
        "reset-cache"      => \$reset_cache,
        "with-attachments" => \$with_attachments,
        "project-id=s"     => \$project_id,
        "wiki-id=s"        => \$wiki_id,
        "drive-id=s"       => \$drive_id,
        "delay=i"          => \$delay,
        "page-id=s"        => \$page_id,
    );
    
    $project_id ||= $config->get('default_project_id');
    $wiki_id    ||= $config->get('default_wiki_id');
    $drive_id   ||= $config->get('default_drive_id');

    $dooray->{delay} = $delay;

    my $cache_file = '.delight_download_cache.sdbm';
    if ($reset_cache) {
        unlink "${cache_file}.dir" if -e "${cache_file}.dir";
        unlink "${cache_file}.pag" if -e "${cache_file}.pag";
        print "Cache reset.\n";
    }
    
    my %cache;
    tie(%cache, 'SDBM_File', $cache_file, O_RDWR|O_CREAT, 0640) or die "Could not open DB file: $!\n";
    
    my $base_dir = base_dir();
    
    make_path($base_dir) unless -d $base_dir;
    
    my sub sanitize_filename {
        my ($name) = @_;
        $name =~ s/[\\\/:\*\?"<>\|]/_/g;
        $name =~ s/^\s+//;
        $name =~ s/\s+$//;
        return $name || 'untitled';
    }

    my sub slugify {
        my ($text) = @_;
        $text = lc($text);
        $text =~ s/[^a-z0-9\x{ac00}-\x{d7af}]+/-/gi; # Keep alphanumeric and Korean
        $text =~ s/^-+|-+$//g;
        return $text || 'page';
    }

    if ($sub eq 'tasks') {
        my @projects;
        if ($project_id) {
            push @projects, { id => $project_id, code => $project_id };
        } else {
            my $res = $dooray->list_projects();
            my $all_projects = $res->{result} || [];
            
            print "Available Projects:\n";
            print "  [0] All Projects\n";
            my $idx = 1;
            foreach my $p (@$all_projects) {
                my $desc = $p->{description} ? " - $p->{description}" : "";
                printf "  [%d] %s%s\n", $idx++, $p->{code}, $desc;
            }
            
            print "\nSelect a project to download (0-" . scalar(@$all_projects) . ") [0]: ";
            my $sel = <STDIN>;
            chomp $sel;
            
            if ($sel && $sel =~ /^\d+$/ && $sel > 0 && $sel <= scalar(@$all_projects)) {
                push @projects, $all_projects->[$sel - 1];
            } else {
                @projects = @$all_projects;
                print "Selected: All Projects\n";
            }
        }
        
        foreach my $proj (@projects) {
            my $pid = $proj->{id};
            my $task_dir = File::Spec->catdir($base_dir, "project_$pid");
            make_path($task_dir) unless -d $task_dir;
            print "Fetching tasks for project $pid...\n";
            my $page = 0;
            my $has_more = 1;
            while ($has_more) {
                my $res = eval { $dooray->list_posts_paginated($pid, $page, 100) };
                if ($@ || !$res->{result}) {
                    warn "Error fetching posts for $pid: $@\n";
                    last;
                }
                my $posts = $res->{result} || [];
                $has_more = @$posts == 100;
                $page++;
                
                foreach my $p (@$posts) {
                    my $post_id = $p->{id};
                    if ($cache{"task_$post_id"}) {
                        next;
                    }
                    
                    print "Downloading task $post_id: $p->{subject}\n";
                    my $detail = eval { $dooray->get_post_detail($pid, $post_id) };
                    next if $@ || !$detail->{result};
                    
                    my $data = $detail->{result};
                    my $format = ($data->{body}{mimeType} || '') eq 'text/html' ? 'html' : 'md';
                    my $content = $data->{body}{content} || '';
                    
                    my $slug = slugify($data->{subject} || 'task');
                    my $fname = "${post_id}-$slug.$format";
                    my $fpath = File::Spec->catfile($task_dir, $fname);
                    
                    open my $fh, '>:utf8', $fpath or warn "Cannot write $fpath: $!";
                    print $fh $content;
                    close $fh;
                    
                    if ($delay) {
                        my $rand_delay = int(rand(9)) + 2; # 2 to 10
                        print "Waiting $rand_delay seconds after downloading...\n";
                        sleep $rand_delay;
                    }

                    if ($with_attachments) {
                        my $files_res = eval { $dooray->get_post_files($pid, $post_id) };
                        if (!$@ && $files_res->{result} && @{$files_res->{result}}) {
                            my $att_dir = File::Spec->catdir($task_dir, "${post_id}_attachments");
                            make_path($att_dir);
                            foreach my $f (@{$files_res->{result}}) {
                                my $f_id = $f->{id};
                                my $dl_url = $dooray->{domain} . "/project/v1/projects/$pid/posts/$post_id/files/$f_id?media=raw";
                                my $f_save = File::Spec->catfile($att_dir, sanitize_filename($f->{name}));
                                eval { $dooray->download_file($dl_url, $f_save) };
                                if ($@) {
                                    warn "Failed to download $f->{name}: $@\n";
                                } else {
                                    if ($delay) {
                                        my $rand_delay = int(rand(9)) + 2;
                                        print "Waiting $rand_delay seconds after downloading...\n";
                                        sleep $rand_delay;
                                    }
                                }
                            }
                        }
                    }
                    
                    $cache{"task_$post_id"} = 1;
                }
            }
        }
    } elsif ($sub eq 'wiki') {
        my @wikis;
        if ($wiki_id) {
            push @wikis, { id => $wiki_id };
        } elsif ($project_id) {
            eval {
                my $resolved_wiki_id = $dooray->get_wiki_id_by_project_id($project_id);
                push @wikis, { id => $resolved_wiki_id };
            };
            if ($@) {
                warn "Failed to resolve wiki-id from project-id $project_id: $@\n";
            }
        } else {
            my $res = eval { $dooray->list_wikis() };
            if (!$@ && $res->{result}) {
                @wikis = @{$res->{result} || []};
            } else {
                warn "Failed to access wikis: $@\n";
            }
        }
        
        my %wiki_tree;   # parent_id -> [child_id, ...]
        my %page_titles; # id -> subject

        foreach my $w (@wikis) {
            my $wid = $w->{id};
            my $wiki_dir = File::Spec->catdir($base_dir, "wiki_$wid");
            make_path($wiki_dir) unless -d $wiki_dir;
            
            if ($page_id) {
                print "Downloading single wiki page $page_id from wiki $wid...\n";
                my $detail = eval { $dooray->get_wiki_page_detail($wid, $page_id) };
                if ($@ || !$detail->{result}) {
                    warn "Error fetching wiki page $page_id: $@\n";
                    next;
                }
                my $data = $detail->{result};
                my $subject = $data->{subject} || 'No Title';
                
                my $format = ($data->{body}{mimeType} || '') eq 'text/html' ? 'html' : 'md';
                my $content = $data->{body}{content} || '';
                
                my $fname = "${page_id}.$format";
                my $fpath = File::Spec->catfile($wiki_dir, $fname);
                
                open my $fh, '>:utf8', $fpath or warn "Cannot write $fpath: $!";
                print $fh $content;
                close $fh;
                print "Saved to $fpath\n";
                next;
            }

            print "Fetching all wiki pages for wiki $wid...\n";
            
            my @parent_queue = (undef); # Start with root pages
            while (@parent_queue) {
                my $current_parent = shift @parent_queue;
                my $page = 0;
                my $has_more = 1;
                while ($has_more) {
                    my $res = eval { $dooray->list_wiki_pages_paginated($wid, $page, 100, parentPageId => $current_parent) };
                    if ($@ || !$res->{result}) {
                        warn "Error fetching wikis for $wid (parent: $current_parent): $@\n";
                        last;
                    }
                    my $pages = $res->{result} || [];
                    $has_more = @$pages == 100;
                    $page++;
                    
                    foreach my $p (@$pages) {
                        my $page_id = $p->{id};
                        my $subject = $p->{subject} || 'No Title';
                        
                        # Build tree structure
                        my $pid_key = $current_parent || 'ROOT';
                        push @{$wiki_tree{$pid_key}}, $page_id;
                        $page_titles{$page_id} = $subject;

                        # Add to queue to fetch its children later
                        push @parent_queue, $page_id;

                        if ($cache{"wiki_$page_id"}) {
                            next;
                        }
                        
                        print "Downloading wiki page $page_id: $subject\n";
                        my $detail = eval { $dooray->get_wiki_page_detail($wid, $page_id) };
                        next if $@ || !$detail->{result};
                        
                        my $data = $detail->{result};
                        my $format = ($data->{body}{mimeType} || '') eq 'text/html' ? 'html' : 'md';
                        my $content = $data->{body}{content} || '';
                        
                        my $fname = "${page_id}.$format";
                        my $fpath = File::Spec->catfile($wiki_dir, $fname);
                        
                        open my $fh, '>:utf8', $fpath or warn "Cannot write $fpath: $!";
                        print $fh $content;
                        close $fh;

                        if ($delay) {
                            my $rand_delay = int(rand(9)) + 2;
                            print "Waiting $rand_delay seconds after downloading...\n";
                            sleep $rand_delay;
                        }
                        
                        if ($with_attachments) {
                            my $files_res = eval { $dooray->get_wiki_page_files($wid, $page_id) };
                            if (!$@ && $files_res->{result} && @{$files_res->{result}}) {
                                my $att_dir = File::Spec->catdir($wiki_dir, "${page_id}_attachments");
                                make_path($att_dir);
                                foreach my $f (@{$files_res->{result}}) {
                                    my $f_id = $f->{id} || $f->{attachFileId};
                                    next unless $f_id;
                                    my $dl_url = $dooray->{domain} . "/wiki/v1/wikis/$wid/pages/$page_id/files/$f_id";
                                    my $f_save = File::Spec->catfile($att_dir, sanitize_filename($f->{name} || $f_id));
                                    eval { $dooray->download_file($dl_url, $f_save) };
                                    if ($@) {
                                        warn "Failed to download $f->{name}: $@\n";
                                    } else {
                                        if ($delay) {
                                            my $rand_delay = int(rand(9)) + 2;
                                            print "Waiting $rand_delay seconds after downloading...\n";
                                            sleep $rand_delay;
                                        }
                                    }
                                }
                            }
                        }
                        $cache{"wiki_$page_id"} = 1;
                    }
                }
            }

            # Generate Hierarchy Map
            my $map_path = File::Spec->catfile($base_dir, "WIKI_MAP_$wid.md");
            open my $mfh, '>:utf8', $map_path or warn "Cannot write map $map_path: $!";
            print $mfh "# Wiki Hierarchy Map ($wid)\n\n";

            my $render_sub;
            $render_sub = sub {
                my ($pid, $depth) = @_;
                foreach my $cid (@{$wiki_tree{$pid} || []}) {
                    my $indent = "  " x $depth;
                    my $bullet = ($depth == 0) ? "" : "- ";
                    printf $mfh "%s%s%s (%s.md)\n", $indent, $bullet, $page_titles{$cid}, $cid;
                    $render_sub->($cid, $depth + 1);
                }
            };
            $render_sub->('ROOT', 0);
            close $mfh;
            print "Wiki map saved to $map_path\n";
        }
    } elsif ($sub eq 'drive') {
        my @drives;
        if ($drive_id) {
            push @drives, { id => $drive_id };
        } else {
            my $res = eval { $dooray->list_drives() };
            if (!$@ && $res->{result}) {
                @drives = @{$res->{result}};
            } else {
                warn "Failed to access org drives, falling back to private drive.\n";
                @drives = ( { id => eval { $dooray->get_private_drive_id() } } );
            }
        }
        
        my $drv_dir = File::Spec->catdir($base_dir, 'drive');
        make_path($drv_dir) unless -d $drv_dir;
        
        foreach my $d (@drives) {
            my $did = $d->{id};
            next unless $did;
            print "Fetching files for drive $did...\n";
            my $page = 0;
            my $has_more = 1;
            while ($has_more) {
                my $res = eval { $dooray->list_files($did, size => 100, page => $page, type => 'file') };
                if ($@ || !$res->{result}) {
                    warn "Error fetching files for drive $did: $@\n";
                    last;
                }
                my $files = $res->{result} || [];
                $has_more = @$files == 100;
                $page++;
                
                foreach my $f (@$files) {
                    my $file_id = $f->{id};
                    if ($cache{"drive_$file_id"}) {
                        next;
                    }
                    
                    print "Downloading drive file $file_id: $f->{name}\n";
                    my $dl_url = $dooray->{domain} . "/drive/v1/drives/$did/files/$file_id?media=raw";
                    my $f_save = File::Spec->catfile($drv_dir, sanitize_filename($f->{name}) . "_$file_id");
                    eval { $dooray->download_file($dl_url, $f_save) };
                    if ($@) {
                        warn "Failed to download $f->{name}: $@\n";
                    } else {
                        $cache{"drive_$file_id"} = 1;
                        if ($delay) {
                            my $rand_delay = int(rand(9)) + 2;
                            print "Waiting $rand_delay seconds after downloading...\n";
                            sleep $rand_delay;
                        }
                    }
                }
            }
        }
    } else {
        print "Usage: delight download tasks|wiki|drive [--reset-cache] [--with-attachments] [--project-id <id>] [--wiki-id <id>] [--drive-id <id>]\n";
    }
    untie %cache;
} elsif ($command eq 'upload') {
    my $sub = shift @ARGV;
    my ($reset_cache, $project_id, $wiki_id, $drive_id, $parent_id, $delay);
    $delay = 1; # Default enable delay
    GetOptions(
        "reset-cache"  => \$reset_cache,
        "project-id=s" => \$project_id,
        "wiki-id=s"    => \$wiki_id,
        "drive-id=s"   => \$drive_id,
        "parent-id=s"  => \$parent_id,
        "delay=i"      => \$delay,
    );
    
    $project_id ||= $config->get('default_project_id');
    $wiki_id    ||= $config->get('default_wiki_id');
    $drive_id   ||= $config->get('default_drive_id');

    my $cache_file = '.delight_upload_cache.sdbm';
    if ($reset_cache) {
        unlink "${cache_file}.dir" if -e "${cache_file}.dir";
        unlink "${cache_file}.pag" if -e "${cache_file}.pag";
        print "Cache reset.\n";
    }
    
    my %cache;
    tie(%cache, 'SDBM_File', $cache_file, O_RDWR|O_CREAT, 0640) or die "Could not open DB file: $!\n";
    
    my $up_dir = $config->get('upload_dir') || File::Spec->catdir(_home(), 'delight_upload');
    make_path($up_dir) unless -d $up_dir;

    if ($sub eq 'drive') {
        unless ($drive_id) {
            if ($project_id) {
                $drive_id = $dooray->get_drive_id_by_project_id($project_id);
            } elsif ($wiki_id) {
                $drive_id = $dooray->get_drive_id_by_wiki_id($wiki_id);
            }
        }
        $drive_id ||= $dooray->get_private_drive_id();
        
        print "Syncing files from $up_dir to Drive $drive_id...\n";
        
        opendir my $dh, $up_dir or die "Cannot open $up_dir: $!";
        my @files = sort grep { -f File::Spec->catfile($up_dir, $_) } readdir $dh;
        closedir $dh;
        
        foreach my $filename (@files) {
            my $fpath = File::Spec->catfile($up_dir, $filename);
            my @st = stat($fpath);
            my $mtime = $st[9];
            my $size  = $st[7];
            
            my $cache_key = "${filename}_${size}_${mtime}";
            if ($cache{$cache_key}) {
                # print "Skipping $filename (already uploaded)\n";
                next;
            }
            
            my $existing_id = $dooray->find_file_by_name($drive_id, $filename, $parent_id);
            
            my $res;
            if ($existing_id) {
                print "Updating $filename (ID: $existing_id)...\n";
                $res = eval { $dooray->update_file($drive_id, $existing_id, $fpath, $filename) };
            } else {
                print "Uploading $filename...\n";
                $res = eval { $dooray->upload_file($drive_id, $fpath, $filename, $parent_id) };
            }

            if ($@) {
                warn "Failed to upload/update $filename: $@\n";
            } else {
                my $new_id = $res->{result}{id};
                $cache{$cache_key} = $new_id;
                print "Sync $filename successfully (ID: $new_id)\n";
                
                if ($delay) {
                    my $rand_delay = int(rand(9)) + 2; # 2 to 10
                    print "Waiting $rand_delay seconds after uploading...\n";
                    sleep $rand_delay;
                }
            }
        }
    } else {
        print "Usage: delight upload drive [--reset-cache] [--project-id <id>] [--wiki-id <id>] [--drive-id <id>] [--parent-id <id>]\n";
    }
    untie %cache;
} elsif ($command eq 'config') {
    my $key = shift @ARGV;
    my $val = shift @ARGV;
    if ($key && $val) {
        $config->set($key, $val);
        $config->save();
        print "Set $key to $val\n";
    } else {
        print "Usage: delight config <key> <value>\n";
    }
} elsif ($command eq 'link') {
    my ($at_start, $one_way);
    GetOptions("start" => \$at_start, "one-way" => \$one_way);
    my @args = @ARGV;
    die "Usage: delight link <a> <b> [--start] [--one-way]\n  a, b: Dooray URL or task:<id> / page:<id>\n" unless @args == 2;

    my @sides = map { _parse_link_target($_) } @args;

    for my $s (@sides) {
        if ($s->{type} eq 'task') {
            $s->{project_id} = resolve_project_id(undef, $s->{id});
            die "Error: project-id not found for task $s->{id}\n" unless $s->{project_id};
            my $detail = $dooray->get_post_detail($s->{project_id}, $s->{id});
            $s->{subject} = $detail->{result}{subject};
            $s->{body}    = $detail->{result}{body}{content} // '';
        } else {
            my $info = $dooray->get_wiki_page($s->{id});
            $s->{wiki_id} = $info->{result}{wikiId};
            die "Error: wiki-id not found for page $s->{id}\n" unless $s->{wiki_id};
            my $wikis = $dooray->list_wikis()->{result} || [];
            for my $w (@$wikis) {
                if ($w->{id} eq $s->{wiki_id}) {
                    $s->{project_id} = $w->{project}{id};
                    last;
                }
            }
            die "Error: project-id not found for wiki $s->{wiki_id}\n" unless $s->{project_id};
            my $detail = $dooray->get_wiki_page_detail($s->{wiki_id}, $s->{id});
            $s->{subject} = $detail->{result}{subject};
            $s->{body}    = $detail->{result}{body}{content} // '';
        }
        my $kind = $s->{type} eq 'task' ? 'tasks' : 'pages';
        $s->{link} = "dooray://$s->{project_id}/$kind/$s->{id}";
    }

    my @directions = $one_way ? (0) : (0, 1);
    for my $i (@directions) {
        my $src = $sides[$i];
        my $dst = $sides[1 - $i];
        my $other_kind = $dst->{type} eq 'task' ? 'tasks' : 'pages';
        if ($src->{body} && $src->{body} =~ m{dooray://[^/\s]+/$other_kind/$dst->{id}\b}) {
            print "Already linked: $src->{type}:$src->{id} -> $dst->{type}:$dst->{id}\n";
            next;
        }
        my $ref_line = "- [$dst->{subject}]($dst->{link})";
        my $new_body = _add_reference($src->{body}, $ref_line, $at_start);

        if ($src->{type} eq 'task') {
            $dooray->update_post($src->{project_id}, $src->{id}, {
                subject => $src->{subject},
                body    => { mimeType => 'text/x-markdown', content => $new_body },
            });
        } else {
            $dooray->update_wiki_page($src->{wiki_id}, $src->{id}, {
                subject => $src->{subject},
                body    => { mimeType => 'text/x-markdown', content => $new_body },
            });
        }
        print "Linked: $src->{type}:$src->{id} -> $dst->{type}:$dst->{id}\n";
    }
} elsif ($command eq 'llm') {
    my $sub = shift @ARGV || 'test';
    if ($sub eq 'test') {
        my $prompt = shift @ARGV;
        unless (defined $prompt) {
            local $/;
            $prompt = <STDIN>;
        }
        $prompt //= 'Reply with exactly: pong';
        my $reply = _llm_complete($prompt);
        print $reply;
        print "\n" unless $reply =~ /\n$/;
    } else {
        print "Usage: delight llm test [<prompt>]   (or pipe prompt via stdin)\n";
    }
} else {
    print "Usage: delight <command> [args]\n";
    print "Commands: whoami, project, calendar, drive, page, task, link, llm, download, upload, config\n";
}
