#!/usr/bin/env perl

use strict;
use warnings;
use FindBin;
use lib "$FindBin::Bin/../lib";
use Delight::Config;
use Delight::Dooray;
use Getopt::Long;
use JSON::MaybeXS;

# Ensure UTF-8 output for terminal
use open qw(:std :utf8);
binmode STDOUT, ":utf8";

my $config = Delight::Config->new();
my $dooray = Delight::Dooray->new(
    token  => $config->get('token'),
    domain => $config->get('domain'),
);

my $command = shift @ARGV || 'help';

# Common variables for subcommands
my ($json_meta, $params_meta, $upload_path, $name, $parent_id, $drive_id, $project_id, $wiki_id, $size);

if ($command eq 'whoami') {
    my $data = $dooray->whoami();
    print "Name: " . $data->{result}{name} . "\n";
    print "Email: " . $data->{result}{externalEmailAddress} . "\n";
} elsif ($command eq 'project') {
    my $sub = shift @ARGV;
    if ($sub eq 'list') {
        my $data = $dooray->list_projects();
        foreach my $p (@{$data->{result}}) {
            printf "%-25s | %s\n", $p->{id}, $p->{code};
        }
    }
} elsif ($command eq 'calendar') {
    my $sub = shift @ARGV;
    if ($sub eq '+agenda') {
        my ($today, $week, $days, $timezone);
        GetOptions(
            "today"      => \$today,
            "week"       => \$week,
            "days=i"     => \$days,
            "timezone=s" => \$timezone,
        );
        use POSIX qw(strftime);
        my $now = time;
        my $duration_days = 1;
        $duration_days = 7 if $week;
        $duration_days = $days if $days;
        
        my $start_of_period = strftime("%Y-%m-%dT00:00:00+09:00", localtime($now));
        my $end_of_period   = strftime("%Y-%m-%dT23:59:59+09:00", localtime($now + ($duration_days - 1) * 86400));
        
        my $data = $dooray->list_events($start_of_period, $end_of_period);
        print "Agenda ($start_of_period to $end_of_period):\n";
        foreach my $event (@{$data->{result}}) {
            my $start = $event->{startedAt} || 'All Day';
            printf " [%-25s] %s\n", $start, $event->{subject};
        }
    } elsif ($sub eq 'events' || $sub eq '+insert' || $sub eq '+quickAdd') {
        my $action = ($sub eq '+insert') ? 'create' : (($sub eq '+quickAdd') ? 'create' : shift @ARGV);
        if ($action eq 'create' || $action eq 'insert' || $action eq 'quickAdd') {
            my ($subject, $summary, $start, $end, $location, $calendar_id, $params_meta, $attendee, $text);
            GetOptions(
                "subject=s"     => \$subject,
                "summary=s"     => \$summary,
                "start=s"       => \$start,
                "end=s"         => \$end,
                "location=s"    => \$location,
                "calendarId=s"  => \$calendar_id,
                "calendar-id=s" => \$calendar_id,
                "params=s"      => \$params_meta,
                "attendee=s"    => \$attendee,
                "text=s"        => \$text,
            );
            $subject ||= $summary || $text || shift @ARGV;
            
            if ($params_meta) {
                my $context = join(' ', $params_meta, @ARGV);
                $context =~ s/\\(["'])/$1/g;
                if ($context =~ /summary\W+([^"',}\s]+)/i || $context =~ /subject\W+([^"',}\s]+)/i) {
                    $subject = $1;
                }
                if ($context =~ /startedAt\W+([^"',}\s]+|{[^}]+})\W+endedAt/i) {
                   # handle nested later if needed
                }
                if ($context =~ /dateTime\W+([^"',}\s]+)/i) {
                    $start = $1;
                }
            }
            
            die "Usage: delight calendar +insert --summary <subject>\n" unless $subject;
            
            
            $calendar_id ||= $config->get('default_calendar_id');
            if (!$calendar_id || $calendar_id eq 'primary') {
                $calendar_id = $dooray->get_default_calendar_id();
            }
            
            use POSIX qw(strftime);
            use Time::Piece;
            my $now = time;
            if ($start) {
                if (!$end) {
                    eval {
                        # Dooray format: 2026-03-22T20:00:00+09:00
                        my $s_clean = $start;
                        $s_clean =~ s/(\+\d{2}):(\d{2})$/$1$2/; # Remove colon for strptime %z
                        my $t = Time::Piece->strptime($s_clean, "%Y-%m-%dT%H:%M:%S%z");
                        my $t_end = $t + 3600;
                        $end = $t_end->strftime("%Y-%m-%dT%H:%M:%S");
                        my $tz = $t_end->strftime("%z");
                        $tz =~ s/(\d{2})(\d{2})$/$1:$2/; # Add colon back
                        $end .= $tz;
                    };
                    if ($@ || !$end) {
                        $end = $start; $end =~ s/T(\d{2})/sprintf("T%02d", ($1+1)%24)/e;
                    }
                }
            } else {
                $start = strftime("%Y-%m-%dT%H:%M:%S+09:00", localtime($now + 3600));
                $end   ||= strftime("%Y-%m-%dT%H:%M:%S+09:00", localtime($now + 7200));
            }
            
            my $event_data = {
                users => { to => [ { type => 'member', member => { organizationMemberId => $dooray->whoami()->{result}{id} } } ] },
                subject => $subject,
                body => { mimeType => "text/plain", content => "Created via Delight CLI" },
                startedAt => $start,
                endedAt   => $end,
                location  => $location || "",
            };
            
            my $res = $dooray->create_event($calendar_id, $event_data);
            print "Event created successfully! ID: " . $res->{result}{id} . "\n";
        } elsif ($action eq 'list') {
            my ($calendar_id, $max_results, $q);
            GetOptions(
                "calendarId=s"  => \$calendar_id,
                "maxResults=i"  => \$max_results,
                "q=s"           => \$q,
            );
            $calendar_id ||= 'primary';
            if ($calendar_id eq 'primary') {
                $calendar_id = '*'; # Dooray wildcard for all calendars the user can see
            }
            
            use POSIX qw(strftime);
            my $now = time;
            my $start = strftime("%Y-%m-%dT00:00:00+09:00", localtime($now - 7 * 86400)); # Last 7 days
            my $end   = strftime("%Y-%m-%dT23:59:59+09:00", localtime($now + 7 * 86400)); # Next 7 days
            
            my $data = $dooray->list_events($start, $end, q => $q, maxResults => $max_results);
            foreach my $event (@{$data->{result}}) {
                printf "%-25s | %-25s | %-25s | %s\n", $event->{id}, $event->{calendar}{id} || "unknown", $event->{startedAt} || "All Day", $event->{subject};
            }
        } elsif ($action eq 'get' || $action eq 'delete') {
            my ($calendar_id, $event_id);
            GetOptions(
                "calendarId=s" => \$calendar_id,
                "eventId=s"    => \$event_id,
            );
            $event_id ||= shift @ARGV;
            die "Usage: delight calendar events $action --eventId <id>\n" unless $event_id;
            
            if (!$calendar_id || $calendar_id eq 'primary') {
                $calendar_id = $dooray->get_default_calendar_id();
            }
            
            if ($action eq 'get') {
                my $res = $dooray->get_event($calendar_id, $event_id);
                print "Event ID:    " . $res->{result}{id} . "\n";
                print "Subject:     " . $res->{result}{subject} . "\n";
                print "Started At:  " . ($res->{result}{startedAt} || "N/A") . "\n";
                print "Ended At:    " . ($res->{result}{endedAt} || "N/A") . "\n";
                print "Location:    " . ($res->{result}{location} || "") . "\n";
            } else {
                $dooray->delete_event($calendar_id, $event_id);
                print "Event deleted successfully.\n";
            }
        }
    } elsif ($sub eq 'freebusy') {
        my $action = shift @ARGV;
        if ($action eq 'query') {
            my $params_meta;
            GetOptions("params=s" => \$params_meta);
            # Note: Dooray free-busy query might need translation from GWS style
            # For now, just pass through if it's JSON
            if ($params_meta) {
                 my $res = $dooray->query_freebusy(decode_json($params_meta));
                 print "Free-Busy Query result:\n";
                 print encode_json($res) . "\n";
            }
        }
    }
} elsif ($command eq 'drive') {
    my $sub = shift @ARGV;
    
    if ($sub eq 'files') {
        my $action = shift @ARGV;
        if ($action eq 'create') {
            GetOptions(
                "json=s"      => \$json_meta,
                "upload=s"    => \$upload_path,
                "name=s"      => \$name,
                "parent-id=s" => \$parent_id,
                "drive-id=s"  => \$drive_id,
                "project-id=s"=> \$project_id,
                "wiki-id=s"   => \$wiki_id,
            );
        } elsif ($action eq 'list') {
            GetOptions(
                "params=s"    => \$params_meta,
                "size=i"      => \$size,
                "drive-id=s"  => \$drive_id,
                "project-id=s"=> \$project_id,
                "wiki-id=s"   => \$wiki_id,
            );
            
            if ($params_meta) {
                my $context = join(' ', $params_meta, @ARGV);
                $context =~ s/\\(["'])/$1/g;
                if ($context =~ /pageSize\W+(\d+)/i) {
                    $size = $1;
                }
            }
            $size ||= 5;
        }
    } elsif ($sub eq '+upload') {
        $upload_path = shift @ARGV;
        GetOptions("name=s" => \$name);
    }
    
    # Common Drive Resolution
    if ($sub eq 'files' || $sub eq '+upload') {
        unless ($drive_id) {
            if ($project_id) {
                $drive_id = $dooray->get_drive_id_by_project_id($project_id);
            } elsif ($wiki_id) {
                $drive_id = $dooray->get_drive_id_by_wiki_id($wiki_id);
            } else {
                my $def_drive   = $config->get('default_drive_id');
                my $def_project = $config->get('default_project_id');
                my $def_wiki    = $config->get('default_wiki_id');
                
                if ($def_drive) {
                    $drive_id = $def_drive;
                } elsif ($def_project) {
                    $drive_id = $dooray->get_drive_id_by_project_id($def_project);
                } elsif ($def_wiki) {
                    $drive_id = $dooray->get_drive_id_by_wiki_id($def_wiki);
                }
            }
        }
        $drive_id ||= $dooray->get_private_drive_id();
    }
    
    if ($upload_path) {
        die "Error: File not found: $upload_path\n" unless -e $upload_path;
        
        if ($json_meta && !$name) {
            my $context = join(' ', $json_meta, @ARGV);
            $context =~ s/\\(["'])/$1/g;
            if ($context =~ /name\W+([^"',}\s]+)/i) {
                $name = $1;
            }
        }
        $name ||= (File::Spec->splitpath($upload_path))[2];
        
        printf "Uploading $upload_path to Drive as '%s'...\n", $name;
        my $result = $dooray->upload_file($drive_id, $upload_path, $name, $parent_id);
        print "Uploaded successfully! File ID: " . $result->{result}{id} . "\n";
    } elsif ($size) {
        my $data = $dooray->list_files($drive_id, size => $size);
        printf "%-25s | %-30s | %s\n", "ID", "Name", "Created At";
        print "-" x 80 . "\n";
        foreach my $file (@{$data->{result}}) {
            printf "%-25s | %-30s | %s\n", $file->{id}, substr($file->{name}, 0, 30), $file->{createdAt};
        }
    } else {
         print "Usage: delight drive files create --upload <path> [options]\n";
         print "       delight drive files list --size <count> [options]\n";
         print "       delight drive +upload <path>\n";
    }
} elsif ($command eq 'post') {
    my $sub = shift @ARGV;
    if ($sub eq 'list') {
        my $project_id = shift @ARGV;
        die "Usage: delight post list <project-id>\n" unless $project_id;
        my $data = $dooray->list_posts($project_id);
        foreach my $post (@{$data->{result}}) {
            printf "%-25s | %s\n", $post->{id}, $post->{subject};
        }
    }
} elsif ($command eq 'config') {
    my $key = shift @ARGV;
    my $val = shift @ARGV;
    if ($key && $val) {
        $config->set($key, $val);
        $config->save();
        print "Set $key to $val\n";
    } else {
        print "Usage: delight config <key> <value>\n";
    }
} else {
    print "Usage: delight <command> [args]\n";
    print "Commands: whoami, project list, post list <pid>, config <key> <val>\n";
}
